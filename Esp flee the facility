                local hackeado = obj:FindFirstChild("Hacked") and obj.Hacked.Value == true
                local corP = hackeado and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(80, 180, 255)
                local corB = hackeado and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(0, 80, 150)
                
                local hl = CriarHighlight(obj, corP, corB)
                if hl then table.insert(highlights["PC"], hl) end
            end
        end
    end

-- ==========================
-- MOTOR DO BOTÃO ESP CÁPSULAS (CORRIGIDO)
-- ==========================
if estados["ESP Cápsulas"] then
    -- 🟡 PRIMEIRO LIMPA TUDO (o segredo para funcionar sempre)
    LimparESP("Capsulas")
    highlights["Capsulas"] = {} -- Cria a lista vazia para guardar eles

    -- Procura por todos os Pods no Workspace
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "Pod" then
            
            -- 🟡 CRIA O MARCADOR E GUARDA NA LISTA
            local hl = CriarHighlight(obj, Color3.fromRGB(255, 200, 0), Color3.fromRGB(180, 120, 0))
            
            -- 🟡 ADICIONA NA LISTA PARA SER CONTROLADO
