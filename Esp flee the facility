-- Função para criar destaque
local function CriarHighlight(alvo, corP, corB)
    if not alvo then return nil end
    -- Verifica se tem alguma parte para destacar
    if not alvo:IsA("BasePart") and not alvo:FindFirstChildWhichIsA("BasePart", true) then return nil end
    
    -- Remove antigo
    if alvo:FindFirstChild("ESP_MARCADOR") then alvo.ESP_MARCADOR:Destroy() end
    
    local hl = Instance.new("Highlight")
    hl.Name = "ESP_MARCADOR"
    hl.Adornee = alvo
    hl.FillColor = corP
    hl.OutlineColor = corB
    hl.FillTransparency = 0.4 -- Mais fraco/transparente
    hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = alvo
    return hl
end

-- Função para limpar grupo
local function LimparESP(nome)
    if highlights[nome] then
        for _, hl in pairs(highlights[nome]) do
            if hl and hl.Parent then hl:Destroy() end
        end
        highlights[nome] = nil
    end
end

