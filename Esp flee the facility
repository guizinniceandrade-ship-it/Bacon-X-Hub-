local function ResponderIA(mensagem)
    local msg = N(mensagem)

    if msg == "comandos" then
        AdicionarMensagem("COMANDOS:\n- resetar -> Apaga o chat\n- treina [frase] -> Ensina frase nova\n- qual jogo -> Digo o jogo atual", false)
        return
    elseif msg == "resetar" then
        for _,v in pairs(Mensagens:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
        return
    elseif msg:match("^treina (.+)$") then
        local frase = msg:match("^treina (.+)$")
        TreinarCadeia({frase})
        AdicionarMensagem("aprendi essa frase! agora faz parte do meu jeito de falar.", false)
        return
    elseif msg:find("qual jogo") or msg:find("que jogo") then
        AdicionarMensagem("voce esta no " .. Cerebro.jogo .. "!", false)
        return
    elseif msg:find("qual meu nome") or msg:find("meu nome") then
        AdicionarMensagem("voce e o " .. Cerebro.nome .. "! ja sei pelo seu perfil.", false)
        return
    end

    local palavraInicial = EncontrarPalavraInicial(msg)
    local resposta = GerarFrase(palavraInicial, math.random(6,14))

    if math.random(1,3) == 1 then
        resposta = Cerebro.nome .. ", " .. resposta
    end

    AdicionarMensagem(resposta, false)
end

local function EnviarMensagem()
    local texto = Input.Text
    if texto == "" then return end
    Input.Text = ""
    AdicionarMensagem(texto, true)
    task.delay(0.4, function() ResponderIA(texto) end)
end

