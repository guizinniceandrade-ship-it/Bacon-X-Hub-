            -- Verifica se já existe um marcador, se não, cria. 
            -- NÃO DESTRUA O MARCADOR TODO FRAME!
            local hl = char:FindFirstChild("ESP_MARCADOR")
            
            if not hl then
                -- Lógica de detectar se é fera (Beast)
                local ehFera = (plr.Team and string.lower(plr.Team.Name):find("beast")) or 
                               char:FindFirstChild("Hammer") or char:FindFirstChild("Mallet") or 
                               (plr.Backpack and (plr.Backpack:FindFirstChild("Hammer") or plr.Backpack:FindFirstChild("Mallet")))

                local corP = ehFera and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(40, 180, 40)
                local corB = ehFera and Color3.fromRGB(120, 20, 20) or Color3.fromRGB(20, 120, 20)
                
                CriarHighlight(char, corP, corB)
