local function AdicionarMensagem(texto, ehUsuario)
    local MsgFrame = Instance.new("Frame")
    MsgFrame.Size = UDim2.new(1, 0, 0, 0)
    MsgFrame.AutomaticSize = Enum.AutomaticSize.Y
    MsgFrame.BackgroundTransparency = 1
    MsgFrame.Parent = Mensagens

    local MsgTexto = Instance.new("TextLabel")
    MsgTexto.Size = UDim2.new(0.85, 0, 0, 0) -- Limita largura para não ficar colada na borda
    MsgTexto.AutomaticSize = Enum.AutomaticSize.Y
    MsgTexto.BackgroundColor3 = ehUsuario and COR_USUARIO or COR_IA
    MsgTexto.Text = texto
    MsgTexto.TextColor3 = COR_TEXTO
    MsgTexto.Font = Enum.Font.Gotham
    MsgTexto.TextSize = 12
    MsgTexto.TextWrapped = true
    MsgTexto.TextXAlignment = Enum.TextXAlignment.Left
    MsgTexto.BorderSizePixel = 0
    MsgTexto.Parent = MsgFrame
    Instance.new("UICorner", MsgTexto).CornerRadius = UDim.new(0,8)
    local pad = Instance.new("UIPadding", MsgTexto)
    pad.PaddingTop = UDim.new(0,6)
    pad.PaddingBottom = UDim.new(0,6)
    pad.PaddingLeft = UDim.new(0,8)
    pad.PaddingRight = UDim.new(0,8)

    -- ✅ ALINHAMENTO PRONTO:
    if ehUsuario then
        MsgTexto.Position = UDim2.new(0.12, 0, 0, 0) -- SUA → DIREITA
        MsgTexto.AnchorPoint = Vector2.new(1, 0)
        MsgTexto.Position = UDim2.new(1, -5, 0, 0)
    else
        MsgTexto.Position = UDim2.new(0, 5, 0, 0) -- IA → ESQUERDA
        MsgTexto.AnchorPoint = Vector2.new(0, 0)
    end

    -- Rola para baixo automaticamente
    Mensagens.CanvasPosition = Vector2.new(0, Mensagens.CanvasSize.Y.Offset)
end

-- LÓGICA DE RESPOSTA
local function ResponderIA(mensagem)
    local msg = mensagem:lower()

    -- COMANDOS ESPECIAIS
    if msg == "comandos!" then
        AdicionarMensagem([[✅ **COMANDOS:**
▫️ **Resetar!** → Apaga tudo
▫️ **ensina que X significa Y** → Eu aprendo
▫️ **meu nome é ...** → Guardo seu nome
▫️ **qual meu nome?** → Eu lembro]], false)
        return
    elseif msg == "resetar!" then
        for _,v in pairs(Mensagens:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
        return
    elseif msg:match("^ensina que (.+) significa (.+)$") then
        local chave, valor = msg:match("^ensina que (.+) significa (.+)$")
        Respostas[chave] = {valor}
        AdicionarMensagem("✅ Aprendi! Sempre que falar \""..chave.."\", vou responder: "..valor, false)
        return
    elseif msg:match("^meu nome é (.+)$") then
        Cerebro.nome = msg:match("^meu nome é (.+)$")
        AdicionarMensagem("😎 Prazer, "..Cerebro.nome.."! Guardei seu nome direitinho.", false)
        return
    elseif msg == "qual meu nome" and Cerebro.nome then
        AdicionarMensagem("Você é o "..Cerebro.nome.."! 😁 Eu não esqueço.", false)
        return
    end

    -- PROCURAR RESPOSTA NA BASE
    for principal, sinonimos in pairs(Respostas) do
        if type(sinonimos) == "table" and #sinonimos > 0 then
            if msg:find(principal) then
                AdicionarMensagem(sinonimos[math.random(#sinonimos)], false)
                return
            end
            if type(sinonimos[1]) == "boolean" then
                for sin, _ in pairs(sinonimos) do
                    if msg:find(sin) then
                        AdicionarMensagem(Respostas[principal][math.random(#Respostas[principal])], false)
                        return
                    end
                end
            end
        end
    end

    -- RESPOSTA PADRÃO SE NÃO SABER
    AdicionarMensagem("🤔 Ainda não sei responder isso... Quer me ensinar? Digite: ensina que "..msg.." significa [o que devo responder]", false)
end

-- ENVIAR MENSAGEM
local function EnviarMensagem()
    local texto = Input.Text
    if texto == "" then return end
    Input.Text = ""
    AdicionarMensagem(texto, true) -- true = usuário (direita)
    task.delay(0.3, function() ResponderIA(texto) end) -- false = IA (esquerda)
end

-- EVENTOS
Enviar.MouseButton1Click:Connect(EnviarMensagem)
Input.ReturnPressedFromOnScreenKeyboard:Connect(EnviarMensagem)
UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.Return and Input:IsFocused() then
        EnviarMensagem()
    end
end)

-- ANIMAÇÃO DE ABRIR/FECHAR
local isOpen = false
local animTween = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
task.delay(0.1, function()
	TweenService:Create(MainFrame, animTween, {Position=UDim2.new(0.5,-200,0.5,-175)}):Play()
	isOpen = true
end)
ToggleButton.MouseButton1Click:Connect(function()
	isOpen = not isOpen
	if isOpen then
		MainFrame.Visible = true
		MainFrame.Position = UDim2.new(0.5,-200,1.5,-175)
		TweenService:Create(MainFrame, animTween, {Position=UDim2.new(0.5,-200,0.5,-175)}):Play()
	else
		local t = TweenService:Create(MainFrame, animTween, {Position=UDim2.new(0.5,-200,1.5,-175)})
		t:Play()
		t.Completed:Connect(function() MainFrame.Visible=false end)
	end
end)

