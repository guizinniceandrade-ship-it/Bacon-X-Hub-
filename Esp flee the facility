-- GERA RESPOSTA INTELIGENTE
-- =========================
local function GerarResposta(msg)
    local msgOriginal = msg
    msg = string.lower(msg)
    Cerebro.conversas += 1

    -- ========== 1. SISTEMA DE ENSINO (MELHORADO) ==========
    if string.find(msg, "ensina que") or string.find(msg, "quando eu digo") or string.find(msg, "aprende") then
        local pergunta = string.match(msgOriginal, "[Ee]nsina que (.+) significa")
                      or string.match(msgOriginal, "[Qq]uando eu digo (.+) responda")
                      or string.match(msgOriginal, "[Qq]uando eu digo (.+) resposta")
                      or string.match(msgOriginal, "[Aa]prende que (.+) =")

        local resposta = string.match(msgOriginal, "significa (.+)")
                      or string.match(msgOriginal, "responda (.+)")
                      or string.match(msgOriginal, "resposta (.+)")
                      or string.match(msgOriginal, "= (.+)")

        if pergunta and resposta then
            pergunta = string.lower(string.gsub(pergunta, "^%s+", ""))
            pergunta = string.gsub(pergunta, "%s+$", "")
            Cerebro.vocabularioAprendido[pergunta] = resposta
            SalvarNaMemoria("sistema", "aprendeu: "..pergunta)
            return "✅ Aprendi direitinho! Quando tu disser '".. pergunta.. "' eu respondo '".. resposta.. "' 🧠"
        else
            return "❌ Formato errado. Usa: **ensina que sol significa calor**"
        end
    end

    -- ========== 2. LEMBRAR HISTÓRICO (MAIS COMPLETO) ==========
    if string.find(msg, "que eu falei") or string.find(msg, "lembra") or string.find(msg, "o que eu disse") then
        -- Última mensagem
        if string.find(msg, "ultima") or string.find(msg, "última") then
            for i = #Cerebro.historicoCompleto, 1, -1 do
                if Cerebro.historicoCompleto[i].quem == "player" then
                    return "📝 Última coisa que tu falou: '".. Cerebro.historicoCompleto[i].texto.. "' às ".. Cerebro.historicoCompleto[i].hora
                end
            end
        end
        -- Todas as mensagens
        local ultimas = ""
        local cont = 0
        for i = #Cerebro.historicoCompleto, 1, -1 do
            if Cerebro.historicoCompleto[i].quem == "player" then
                cont += 1
                ultimas = ultimas .. "\n• ".. Cerebro.historicoCompleto[i].texto
                if cont >= 3 then break end
            end
        end
        if ultimas ~= "" then
            return "🧠 Lembro dessas que tu falou: ".. ultimas
        else
            return "A gente ainda não conversou muito kkkk"
        end
    end

    -- ========== 3. RESPOSTAS PRONTAS E INTELIGENTES ==========
    for padrao, respostas in pairs(RespostasInteligentes) do
        if string.find(msg, padrao, 1, true) then
            return respostas[math.random(1, #respostas)]
        end
    end

    -- ========== 4. BUSCA NO VOCABULÁRIO ==========
    local respostaAprendida = BuscarNoVocabulario(msg)
    if respostaAprendida then
        return respostaAprendida
    end

    -- ========== 5. CALCULADORA CORRIGIDA ==========
    local calculo = string.match(msg, "^[%d%+%-%*/%.%s%(%)]+$")
    if calculo then
        local resultado = CalcularExpressao(calculo)
        if resultado then
            return "🧮 Resultado: ".. resultado
        end
    end

    -- ========== 6. SISTEMA DE NOME ==========
    if string.find(msg, "meu nome e") or string.find(msg, "meu nome é") or string.find(msg, "me chama de") then
        local nome = string.match(msgOriginal, "[Mm]eu nome [eé] ([%w_À-ú]+)")
                  or string.match(msgOriginal, "[Mm]e chama de ([%w_À-ú]+)")
        if nome then
            Cerebro.nome = nome
            SalvarNaMemoria("sistema", "nome: "..nome)
            return "✅ Salvei, ".. nome.. "! Agora sempre vou te chamar assim 🧠"
        end
    end

    if string.find(msg, "qual meu nome") or string.find(msg, "quem sou eu") then
        if Cerebro.nome then
            return "Tu é o ".. Cerebro.nome.. " 🫡"
        else
            return "Não sei ainda. Fala: **meu nome é [seu nome]**"
        end
    end

    -- ========== 7. COMANDOS AVANÇADOS ==========
    if string.find(msg, "apaga memoria") or string.find(msg, "esquece tudo") then
        Cerebro.vocabularioAprendido = {}
        Cerebro.historicoCompleto = {}
        Cerebro.nome = nil
        return "🗑️ Memória resetada! Sou novo em folha, não lembro de nada kkkk"
    end

    if string.find(msg, "quant") and string.find(msg, "palavra") then
        local qtd = 0
        for _ in pairs(Cerebro.vocabularioAprendido) do qtd += 1 end
        return "📊 Estatísticas:\n• Aprendi: ".. qtd.. " coisas\n• Lembro de: ".. #Cerebro.historicoCompleto.. " mensagens\n• Conversamos: ".. Cerebro.conversas.. " vezes"
    end

    if string.find(msg, "piada") then
        local piadas = {
            "Por que o dev foi no médico? Com dor de back-end 😂",
            "O que o HTML disse pro CSS? Que estilo é esse meu amigo? 😂",
            "Por que o robô não tem amigos? Porque ele é muito 'rígido' kkk"
        }
        return piadas[math.random(1, #piadas)]
    end

    if string.find(msg, "dado") then
        return "🎲 Número sorteado: ".. math.random(1, 6)
    end

    if string.find(msg, "hora") or string.find(msg, "horas") then
        return "🕒 Agora são: ".. os.date("%H:%M:%S")
    end

    if string.find(msg, "data") or string.find(msg, "dia") then
        return "📅 Hoje é: ".. os.date("%d/%m/%Y")
    end

    -- ========== 8. INTERAÇÕES SOCIAIS ==========
    if string.match(msg, "k+") or string.match(msg, "h+a+h+") or string.match(msg, "rs+") or string.match(msg, "😂") then
        local qtdK = #string.match(msg, "k+") or 3
        return string.rep("k", math.clamp(qtdK + math.random(1,3), 4, 15)).. " 😂🤣"
    end

    if string.match(msg, "^oi") or string.match(msg, "^ola") or string.match(msg, "^salve") or string.match(msg, "^e ai") or string.match(msg, "^opa") then
        local resp = {"E aí", "Opa", "Salve", "Fala aí", "Beleza?"}[math.random(1,5)]
        if Cerebro.nome then resp = resp.. " ".. Cerebro.nome.. "! Tudo bem?" end
        return resp
    end

    -- ========== 9. NÃO ENTENDEU (MELHORADO) ==========
    return NaoEntendi[math.random(1, #NaoEntendi)]
end

