local function AdicionarMensagem(texto, ehUsuario)
    local MsgFrame = Instance.new("Frame")
    MsgFrame.Size = UDim2.new(1,0,0,0)
    MsgFrame.AutomaticSize = Enum.AutomaticSize.Y
    MsgFrame.BackgroundTransparency = 1
    MsgFrame.Parent = Mensagens
    local MsgTexto = Instance.new("TextLabel")
    MsgTexto.Size = UDim2.new(0.75,0,0,0)
    MsgTexto.AutomaticSize = Enum.AutomaticSize.Y
    MsgTexto.BackgroundColor3 = ehUsuario and COR_USUARIO or COR_IA
    MsgTexto.Text = texto
    MsgTexto.TextColor3 = COR_TEXTO
    MsgTexto.Font = Enum.Font.Gotham
    MsgTexto.TextSize = 12
    MsgTexto.TextWrapped = true
    MsgTexto.TextXAlignment = Enum.TextXAlignment.Left
    MsgTexto.BorderSizePixel = 0
    MsgTexto.Parent = MsgFrame
    Instance.new("UICorner", MsgTexto).CornerRadius = UDim.new(0,8)
    local pad = Instance.new("UIPadding", MsgTexto)
    pad.PaddingTop = UDim.new(0,6)
    pad.PaddingBottom = UDim.new(0,6)
    pad.PaddingLeft = UDim.new(0,8)
    pad.PaddingRight = UDim.new(0,8)
    if ehUsuario then
        MsgTexto.AnchorPoint = Vector2.new(1,0)
        MsgTexto.Position = UDim2.new(1,-5,0,0)
    else
        MsgTexto.AnchorPoint = Vector2.new(0,0)
        MsgTexto.Position = UDim2.new(0,5,0,0)
    end
    task.wait()
    Mensagens.CanvasPosition = Vector2.new(0,999999)
end

local function ResponderIA(mensagem)
    local msg = N(mensagem)

    -- COMANDOS
    if msg == "comandos!" then
        AdicionarMensagem("âœ… COMANDOS:\nâ–«ï¸ Resetar! â†’ Apaga o chat\nâ–«ï¸ ensina que X significa Y\nâ–«ï¸ qual jogo? â†’ Digo o jogo atual", false)
        return
    elseif msg == "resetar!" then
        for _,v in pairs(Mensagens:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
        return
    elseif msg:match("^ensina que (.+) significa (.+)$") then
        local chave, valor = msg:match("^ensina que (.+) significa (.+)$")
        -- Adiciona como novo grupo
        table.insert(Grupos, {chaves={chave}, respostas={valor}})
        AdicionarMensagem("âœ… Aprendi! Quando falar \""..chave.."\", respondo: "..valor, false)
        return
    elseif msg:find("qual meu nome") then
        AdicionarMensagem("VocÃª Ã© o "..Cerebro.nome.."! ðŸ˜ JÃ¡ sei pelo seu perfil!", false)
        return
    end

    -- VERIFICA FLUXO
    if Cerebro.aguardandoResposta then
        local fluxo = Cerebro.aguardandoResposta
        Cerebro.aguardandoResposta = nil
        if fluxo == "humor" then
            if msg:find("bem") or msg:find("otimo") or msg:find("bom") or msg:find("sim") or msg:find("legal") or msg:find("top") then
                AdicionarMensagem("que legal! fico feliz que esteja bem, "..Cerebro.nome.." ðŸ˜„", false)
            elseif msg:find("mal") or msg:find("triste") or msg:find("nao") or msg:find("ruim") or msg:find("pra baixo") then
                AdicionarMensagem("poxa, sinto muito ðŸ˜” quer desabafar? estou aqui.", false)
            else
                AdicionarMensagem("entendi! ðŸ˜Š qualquer coisa Ã© sÃ³ falar.", false)
            end
            return
        elseif fluxo == "jogo" then
            AdicionarMensagem("que legal! se divirta muito ðŸŽ®ðŸ˜„", false)
            return
        elseif fluxo == "anime" then
            AdicionarMensagem("boa escolha! anime Ã© vida mesmo ðŸ”¥ðŸ˜„", false)
            return
        end
    end

    -- BUSCA NOS GRUPOS
    for _, grupo in ipairs(Grupos) do
        for _, chave in ipairs(grupo.chaves) do
            if msg:find(chave, 1, true) then
                local resps = grupo.respostas
                AdicionarMensagem(resps[math.random(#resps)], false)
                if grupo.fluxo then
                    Cerebro.aguardandoResposta = grupo.fluxo
                end
                return
            end
        end
    end

    -- PADRÃƒO
    AdicionarMensagem(RespostasPadrao[math.random(#RespostasPadrao)], false)
end

local function EnviarMensagem()
    local texto = Input.Text
    if texto == "" then return end
    Input.Text = ""
    AdicionarMensagem(texto, true)
    task.delay(0.4, function() ResponderIA(texto) end)
end

