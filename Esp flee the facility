local Cadeia = {}

local function TreinarCadeia(frases)
    for _, frase in ipairs(frases) do
        local palavras = {}
        for palavra in frase:gmatch("%S+") do
            table.insert(palavras, palavra)
        end
        for i = 1, #palavras - 1 do
            local atual = palavras[i]
            local proxima = palavras[i + 1]
            if not Cadeia[atual] then Cadeia[atual] = {} end
            table.insert(Cadeia[atual], proxima)
        end
    end
end

TreinarCadeia(FrasesTreino)

local function GerarFrase(palavraInicial, tamanhoMax)
    tamanhoMax = tamanhoMax or math.random(6, 12)
    local frase = {palavraInicial}
    local atual = palavraInicial
    for i = 1, tamanhoMax do
        if Cadeia[atual] and #Cadeia[atual] > 0 then
            local proximas = Cadeia[atual]
            atual = proximas[math.random(#proximas)]
            table.insert(frase, atual)
        else
            break
        end
    end
    return table.concat(frase, " ")
end

local function EncontrarPalavraInicial(msg)
    local palavrasMsg = {}
    for palavra in msg:gmatch("%S+") do
        table.insert(palavrasMsg, palavra)
    end
    for _, palavra in ipairs(palavrasMsg) do
        if Cadeia[palavra] then return palavra end
    end
    local iniciadores = {"oi","ola","que","isso","voce","estou","tudo","legal","bom","sim","nao","vai"}
    for _, ini in ipairs(iniciadores) do
        if Cadeia[ini] then return ini end
    end
    local todasPalavras = {}
    for palavra, _ in pairs(Cadeia) do table.insert(todasPalavras, palavra) end
    return todasPalavras[math.random(#todasPalavras)]
end

local function N(msg)
    msg = msg:lower()
    msg = msg:gsub("[^%a%d%s]", "")
    return msg
end

