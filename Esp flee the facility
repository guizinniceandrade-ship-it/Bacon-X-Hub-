-- FUNÇÃO PARA PROCURAR RESPOSTA
local function PegarResposta(mensagem)
    mensagem=string.lower(mensagem)
    mensagem=string.gsub(mensagem,"[áàâãä]","a")
    mensagem=string.gsub(mensagem,"[éèêë]","e")
    mensagem=string.gsub(mensagem,"[íìîï]","i")
    mensagem=string.gsub(mensagem,"[óòôõö]","o")
    mensagem=string.gsub(mensagem,"[úùûü]","u")
    mensagem=string.gsub(mensagem,"[ç]","c")
    mensagem=string.gsub(mensagem,"%p","") -- REMOVER PONTUAÇÃO

    -- PERCORRER TODAS AS PALAVRAS CHAVE
    for chave,sinonimos in pairs(Respostas) do
        -- VERIFICAR SE A MENSAGEM TEM A PALAVRA CHAVE
        if string.find(mensagem,chave) then
            -- PEGAR UMA RESPOSTA ALEATÓRIA
            local lista=Respostas[chave]
            return lista[math.random(1,#lista)]
        end
        -- VERIFICAR SINÔNIMOS
        for sin in pairs(sinonimos) do
            if string.find(mensagem,sin) then
                local lista=Respostas[chave]
                return lista[math.random(1,#lista)]
            end
        end
    end

    -- RESPOSTA PADRÃO SE NÃO ENTENDER
    local respostasPadrao={
        "hummm... não entendi muito bem 😅 pode falar de outro jeito?",
        "não sei te responder isso ainda 🤔 me ensina o que significa?",
        "não entendi direito 🧐 pode explicar melhor?",
        "não conheço essa palavra/assunto 😅 pode falar mais simples?",
        "não entendi muito bem o que você quis dizer 🤔"
    }
    return respostasPadrao[math.random(1,#respostasPadrao)]
end

