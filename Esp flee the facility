local function SalvarNaMemoria(quem, texto)
    table.insert(Cerebro.historicoCompleto, {
        quem = quem,
        texto = texto,
        hora = os.date("%H:%M")
    })
    -- Mantém só últimas 200 mensagens
    if #Cerebro.historicoCompleto > 200 then
        table.remove(Cerebro.historicoCompleto, 1)
    end

    -- Salva na DataStore de forma segura
    if BotMemoryStore then
        task.spawn(function()
            pcall(function()
                BotMemoryStore:SetAsync("dados", {
                    nome = Cerebro.nome,
                    vocabulario = Cerebro.vocabularioAprendido
                })
            end)
        end)
    end
end

-- Busca palavras-chave (não só igualdade exata)
local function BuscarNoVocabulario(msg)
    msg = string.lower(msg)
    -- 1. Busca exata
    for pergunta, resposta in pairs(Cerebro.vocabularioAprendido) do
        if string.find(msg, pergunta, 1, true) then
            return resposta
        end
    end
    -- 2. Busca parcial (mais esperto)
    for pergunta, resposta in pairs(Cerebro.vocabularioAprendido) do
        local palavras = string.split(pergunta, " ")
        local acertos = 0
        for _, p in ipairs(palavras) do
            if #p > 2 and string.find(msg, p, 1, true) then
                acertos += 1
            end
        end
        if acertos >= math.ceil(#palavras * 0.7) then -- 70% de semelhança
            return resposta
        end
    end
    return nil
end

-- Calculadora segura (substituí loadstring que é bloqueado)
local function CalcularExpressao(expr)
    expr = string.gsub(expr, "%s", "")
    -- Permite só números e operadores básicos
    if not string.match(expr, "^[%d%+%-%*/%.%(%)]+$") then return nil end

    -- Implementação simples sem loadstring
    local funcoes = {
        ["+"] = function(a,b) return a+b end,
        ["-"] = function(a,b) return a-b end,
        ["*"] = function(a,b) return a*b end,
        ["/"] = function(a,b) if b==0 then return "Erro: divisão por zero" end return a/b end
    }

    -- Resolve parênteses primeiro
    while string.find(expr, "%(") do
        local dentro = string.match(expr, "%(([^%(%)]+)%)")
        if not dentro then break end
        local res = CalcularExpressao(dentro)
        expr = string.gsub(expr, "%("..dentro.."%)", tostring(res), 1)
    end

    -- Resolve multiplicação e divisão
    while string.find(expr, "[%*/]") do
        local a, op, b = string.match(expr, "(%d+%.?%d*)([%*/])(%d+%.?%d*)")
        if not a then break end
        local resultado = funcoes[op](tonumber(a), tonumber(b))
        expr = string.gsub(expr, a..op..b, tostring(resultado), 1)
    end

    -- Resolve soma e subtração
    while string.find(expr, "[%+%-]", 2) do -- ignora o primeiro sinal se for negativo
        local a, op, b = string.match(expr, "(%d+%.?%d*)([%+%-])(%d+%.?%d*)")
        if not a then break end
        local resultado = funcoes[op](tonumber(a), tonumber(b))
        expr = string.gsub(expr, a..op..b, tostring(resultado), 1)
    end

    return tonumber(expr) or expr
end

