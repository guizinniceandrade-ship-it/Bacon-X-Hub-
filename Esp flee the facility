local function N(msg)
    msg = msg:lower()
    msg = msg:gsub("a","a"):gsub("a","a"):gsub("a","a"):gsub("a","a")
             :gsub("e","e"):gsub("e","e"):gsub("i","i"):gsub("o","o")
             :gsub("o","o"):gsub("o","o"):gsub("u","u"):gsub("c","c")
    msg = msg:gsub("[^%a%d%s]", "")
    return msg
end

