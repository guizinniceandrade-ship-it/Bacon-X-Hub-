    MsgTexto.TextXAlignment = Enum.TextXAlignment.Left
    MsgTexto.BorderSizePixel = 0
    MsgTexto.Parent = MsgFrame
    Instance.new("UICorner", MsgTexto).CornerRadius = UDim.new(0,8)
    local pad = Instance.new("UIPadding", MsgTexto)
    pad.PaddingTop = UDim.new(0,6)
    pad.PaddingBottom = UDim.new(0,6)
    pad.PaddingLeft = UDim.new(0,8)
    pad.PaddingRight = UDim.new(0,8)
    if ehUsuario then
        MsgTexto.AnchorPoint = Vector2.new(1,0)
        MsgTexto.Position = UDim2.new(1,-5,0,0)
    else
        MsgTexto.AnchorPoint = Vector2.new(0,0)
        MsgTexto.Position = UDim2.new(0,5,0,0)
    end
    task.wait()
    Mensagens.CanvasPosition = Vector2.new(0,999999)
end

local function ResponderIA(mensagem)
    local msg = N(mensagem)

    if msg == "comandos" then
        AdicionarMensagem("COMANDOS:\n- Resetar! -> Apaga o chat\n- ensina que X significa Y\n- qual jogo? -> Digo o jogo", false)
        return
    elseif msg == "resetar" then
        for _,v in pairs(Mensagens:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
        return
    elseif mensagem:lower():match("^ensina que (.+) significa (.+)$") then
        local chave, valor = mensagem:lower():match("^ensina que (.+) significa (.+)$")
        table.insert(Grupos, {chaves={chave}, respostas={valor}})
        AdicionarMensagem("Aprendi! Quando falar \"" .. chave .. "\", respondo: " .. valor, false)
        return
    elseif msg:find("qual meu nome") then
        AdicionarMensagem("Voce e o " .. Cerebro.nome .. "! Ja sei pelo seu perfil!", false)
        return
    end

    -- FLUXO DE CONVERSA
    if Cerebro.aguardandoResposta then
        local fluxo = Cerebro.aguardandoResposta
        Cerebro.aguardandoResposta = nil
        if fluxo == "humor" then
            if msg:find("bem") or msg:find("otimo") or msg:find("bom") or msg:find("sim") or msg:find("legal") or msg:find("top") then
                AdicionarMensagem("que legal! fico feliz que esteja bem, " .. Cerebro.nome .. "!", false)
            elseif msg:find("mal") or msg:find("triste") or msg:find("nao") or msg:find("ruim") then
                AdicionarMensagem("poxa, sinto muito... quer desabafar? estou aqui.", false)
            else
                AdicionarMensagem("entendi! qualquer coisa e so falar.", false)
            end
            return
        elseif fluxo == "jogo" then
            AdicionarMensagem("que legal! se divirta muito!", false)
            return
        elseif fluxo == "anime" then
            AdicionarMensagem("boa escolha! anime e vida mesmo!", false)
            return
        end
    end

    -- BUSCA NOS GRUPOS
    for _, grupo in ipairs(Grupos) do
        for _, chave in ipairs(grupo.chaves) do
            if msg:find(chave, 1, true) then
                local resps = grupo.respostas
                AdicionarMensagem(resps[math.random(#resps)], false)
                if grupo.fluxo then
                    Cerebro.aguardandoResposta = grupo.fluxo
                end
                return
            end
        end
    end

    AdicionarMensagem(RespostasPadrao[math.random(#RespostasPadrao)], false)
end

local function EnviarMensagem()
    local texto = Input.Text
    if texto == "" then return end
    Input.Text = ""
    AdicionarMensagem(texto, true)
    task.delay(0.4, function() ResponderIA(texto) end)
end

Enviar.MouseButton1Click:Connect(EnviarMensagem)
Input.ReturnPressedFromOnScreenKeyboard:Connect(EnviarMensagem)
UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Keyboard
    and input.KeyCode == Enum.KeyCode.Return
    and Input:IsFocused() then
        EnviarMensagem()
    end
end)

