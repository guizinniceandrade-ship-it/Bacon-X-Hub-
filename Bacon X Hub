-- [1] ABA: MURDERER (Lógica Kill Aura Pronta)
-- ==========================================
_G.KillAuraAtivado = false
_G.DistanciaKillAura = 30

local function ObterAlvoValido()
    local MaisProximo = nil
    local MenorDistancia = math.huge
    local MeuChar = LocalPlayer.Character
    if not MeuChar or not MeuChar:FindFirstChild("HumanoidRootPart") then return nil end
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") then
            if v.Character.Humanoid.Health > 0 and not v.Character:FindFirstChild("ForceField") then 
                local Distancia = (MeuChar.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
                if Distancia < _G.DistanciaKillAura and Distancia < MenorDistancia then
                    MenorDistancia = Distancia
                    MaisProximo = v.Character
                end
            end
        end
    end
    return MaisProximo
end

task.spawn(function()
    while task.wait(0.1) do
        if _G.KillAuraAtivado then
            local MeuChar = LocalPlayer.Character
            if MeuChar and MeuChar:FindFirstChild("HumanoidRootPart") then
                local ItemEquipado = MeuChar:FindFirstChildOfClass("Tool")
                if ItemEquipado and ItemEquipado.Name == "Knife" then
                    local Alvo = ObterAlvoValido()
                    if Alvo and Alvo:FindFirstChild("HumanoidRootPart") then
                        local PosicaoFrente = MeuChar.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3.5)
                        Alvo.HumanoidRootPart.CFrame = PosicaoFrente
                        if ItemEquipado:FindFirstChild("Click") then
                            ItemEquipado.Click:FireServer()
                        end
                    end
                end
            end
        end
    end
end)

