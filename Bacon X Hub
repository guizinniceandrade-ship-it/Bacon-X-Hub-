-- Função estável para pegar o Character e o Humanoid do jogador
local function GetCharacterElements()
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        return char, hum, root
    end
    return nil, nil, nil
end

-- 1 & 2. FUNCIONAMENTO DA VELOCIDADE (WalkSpeed)
task.spawn(function()
    while task.wait(0.1) do
        local _, hum, _ = GetCharacterElements()
        if hum then
            if _G.SpeedActive then
                hum.WalkSpeed = _G.WalkSpeedValue or 16
            else
                -- Se desligar o botão, volta ao padrão do Roblox (16)
                if hum.WalkSpeed ~= 16 and not _G.SpeedActive then
                    hum.WalkSpeed = 16
                end
            end
        end
    end
end)

