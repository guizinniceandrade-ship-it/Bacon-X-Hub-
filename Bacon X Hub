local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

-- Remove versão anterior para não duplicar
local Antigo = game:GetService("CoreGui"):FindFirstChild("BaconXHubV1") or LocalPlayer:FindFirstChildOfClass("PlayerGui"):FindFirstChild("BaconXHubV1")
if Antigo then Antigo:Destroy() end

-- ScreenGui Principal
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "BaconXHubV1"
ScreenGui.ResetOnSpawn = false
pcall(function() ScreenGui.Parent = game:GetService("CoreGui") end)
if not ScreenGui.Parent then ScreenGui.Parent = LocalPlayer:FindFirstChildOfClass("PlayerGui") end

-- =============================================================================
-- JANELA PRINCIPAL (550x350 - Toda Preta com Bordas Arredondadas Perfeitas)
-- =============================================================================
local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Toda preta
MainFrame.Position = UDim2.new(0.5, -275, 1.5, 0) -- Começa embaixo para a animação
MainFrame.Size = UDim2.new(0, 550, 0, 350)        -- Tamanho exato pedido
MainFrame.ClipsDescendants = true
MainFrame.Visible = false

local MainCorner = Instance.new("UICorner")
MainCorner.CornerRadius = UDim.new(0, 10) -- Arredonda todas as bordas perfeitamente
MainCorner.Parent = MainFrame

-- Topo para Arrastar (Transparente para não cobrir o arredondamento dos cantos de cima)
local TopBar = Instance.new("Frame")
TopBar.Name = "TopBar"
TopBar.Parent = MainFrame
TopBar.BackgroundTransparency = 1
TopBar.Size = UDim2.new(1, 0, 0, 40)

local HubTitle = Instance.new("TextLabel")
HubTitle.Parent = TopBar
HubTitle.BackgroundTransparency = 1
HubTitle.Position = UDim2.new(0, 15, 0, 0)
HubTitle.Size = UDim2.new(1, -15, 1, 0)
HubTitle.Font = Enum.Font.GothamBold
HubTitle.Text = "Bacon X Hub v1"
HubTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
HubTitle.TextSize = 14
HubTitle.TextXAlignment = Enum.TextXAlignment.Left

-- Linha Azul abaixo do título
local Line = Instance.new("Frame")
Line.Parent = TopBar
Line.Position = UDim2.new(0, 10, 1, -2)
Line.Size = UDim2.new(1, -20, 0, 2)
Line.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
Line.BorderSizePixel = 0

-- =============================================================================
-- PAINEL LATERAL ESQUERDO (Rolagem para as 15 Abas)
-- =============================================================================
local NavigationScroll = Instance.new("ScrollingFrame")
NavigationScroll.Name = "NavigationScroll"
NavigationScroll.Parent = MainFrame
NavigationScroll.Position = UDim2.new(0, 10, 0, 50)
NavigationScroll.Size = UDim2.new(0, 140, 1, -65)
NavigationScroll.BackgroundTransparency = 1
NavigationScroll.ScrollBarThickness = 2
NavigationScroll.ScrollBarImageColor3 = Color3.fromRGB(0, 150, 255)

local NavList = Instance.new("UIListLayout")
NavList.Parent = NavigationScroll
NavList.SortOrder = Enum.SortOrder.LayoutOrder
NavList.Padding = UDim.new(0, 5)

-- Ajuste automático do tamanho da rolagem das abas (Igual ao que você pediu)
NavList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    NavigationScroll.CanvasSize = UDim2.new(0, 0, 0, NavList.AbsoluteContentSize.Y + 10)
end)

-- Container do Lado Direito
local ContentContainer = Instance.new("Frame")
ContentContainer.Name = "ContentContainer"
ContentContainer.Parent = MainFrame
ContentContainer.Position = UDim2.new(0, 160, 0, 50)
ContentContainer.Size = UDim2.new(1, -170, 1, -65)
ContentContainer.BackgroundTransparency = 1

-- =============================================================================
-- CRIAÇÃO AUTOMÁTICA DAS 15 ABAS COM SISTEMA DE ROLAGEM IDENTICO
-- =============================================================================
local abas = {
    "Murderer", "Sherif", "Inocente", "Esp", "Auto Farm", 
    "Local player", "Estatus do servidor", "Settings", "Misc", "Perfil",
    "Teleports", "Combat", "Visuals", "Skins", "Creditos"
}

local paginas = {}
local botoesAba = {}

for i, nomeAba in ipairs(abas) do
    -- Criando a página de rolagem de CADA aba (com o mesmo sistema de rolagem)
    local PaginaScroll = Instance.new("ScrollingFrame")
    PaginaScroll.Name = nomeAba .. "Page"
    PaginaScroll.Parent = ContentContainer
    PaginaScroll.Size = UDim2.new(1, 0, 1, 0)
    PaginaScroll.BackgroundTransparency = 1
    PaginaScroll.Visible = false
    PaginaScroll.ScrollBarThickness = 2
    PaginaScroll.ScrollBarImageColor3 = Color3.fromRGB(0, 150, 255)
    
    local PaginaList = Instance.new("UIListLayout")
    PaginaList.Parent = PaginaScroll
    PaginaList.SortOrder = Enum.SortOrder.LayoutOrder
    PaginaList.Padding = UDim.new(0, 6)
    
    -- Sistema de rolagem idêntico para a parte interna de cada aba
    PaginaList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        PaginaScroll.CanvasSize = UDim2.new(0, 0, 0, PaginaList.AbsoluteContentSize.Y + 10)
    end)
    
    paginas[nomeAba] = PaginaScroll

    -- Criando o botão correspondente no painel esquerdo
    local BotaoAba = Instance.new("TextButton")
    BotaoAba.Name = nomeAba .. "Btn"
    BotaoAba.Parent = NavigationScroll
    BotaoAba.Size = UDim2.new(1, -6, 0, 32)
    BotaoAba.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    BotaoAba.Font = Enum.Font.GothamBold
    BotaoAba.Text = "  " .. nomeAba
    BotaoAba.TextColor3 = Color3.fromRGB(150, 150, 150)
    BotaoAba.TextSize = 11
    BotaoAba.TextXAlignment = Enum.TextXAlignment.Left
    BotaoAba.LayoutOrder = i
    
    local BotaoCorner = Instance.new("UICorner")
    BotaoCorner.CornerRadius = UDim.new(0, 4)
    BotaoCorner.Parent = BotaoAba
    
    botoesAba[nomeAba] = BotaoAba

    -- Alternar entre as abas
    BotaoAba.MouseButton1Click:Connect(function()
        for _, nome in pairs(abas) do
            paginas[nome].Visible = false
            botoesAba[nome].BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            botoesAba[nome].TextColor3 = Color3.fromRGB(150, 150, 150)
        end
        PaginaScroll.Visible = true
        BotaoAba.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        BotaoAba.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
end

-- Deixa a primeira aba aberta por padrão
paginas["Murderer"].Visible = true
botoesAba["Murderer"].BackgroundColor3 = Color3.fromRGB(30, 30, 30)
botoesAba["Murderer"].TextColor3 = Color3.fromRGB(255, 255, 255)

-- =============================================================================
-- SISTEMA DE ARRASTAR A JANELA PRINCIPAL (Mobile & PC)
-- =============================================================================
local dragging, dragStart, startPos
TopBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = i.Position; startPos = MainFrame.Position end end)
UserInputService.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then local delta = i.Position - dragStart; MainFrame.Position = startPos + UDim2.new(0, delta.X, 0, delta.Y) end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

-- =============================================================================
-- NOTIFICAÇÕES & ANIMAÇÃO DE SUBIDA (Vem de baixo e centraliza)
-- =============================================================================
local function CriarNotificacao(titulo, msg, tempo)
    local N = Instance.new("Frame", ScreenGui)
    N.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    N.Size = UDim2.new(0, 250, 0, 60)
    N.Position = UDim2.new(1, 30, 1, -100)
    Instance.new("UICorner", N).CornerRadius = UDim.new(0, 5)
    
    local l1 = Instance.new("TextLabel", N); l1.Text = titulo; l1.Size = UDim2.new(1, -20, 0, 20); l1.Position = UDim2.new(0, 10, 0, 5); l1.BackgroundTransparency = 1; l1.TextColor3 = Color3.fromRGB(255, 255, 255); l1.Font = Enum.Font.GothamBold; l1.TextSize = 12; l1.TextXAlignment = Enum.TextXAlignment.Left
    local l2 = Instance.new("TextLabel", N); l2.Text = msg; l2.Size = UDim2.new(1, -20, 0, 30); l2.Position = UDim2.new(0, 10, 0, 25); l2.BackgroundTransparency = 1; l2.TextColor3 = Color3.fromRGB(160, 160, 160); l2.Font = Enum.Font.Gotham; l2.TextSize = 11; l2.TextXAlignment = Enum.TextXAlignment.Left; l2.TextWrapped = true

    N:TweenPosition(UDim2.new(1, -270, 1, -100), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.4, true)
    task.wait(tempo)
    N:TweenPosition(UDim2.new(1, 30, 1, -100), Enum.EasingDirection.In, Enum.EasingStyle.Quart, 0.4, true)
    task.wait(0.4)
    N:Destroy()
end

-- Sequência de carregamento limpa antes de subir a interface
task.spawn(function()
    CriarNotificacao("Bacon X Hub v1", "Carregando a estrutura...", 2)
    CriarNotificacao("Bacon X Hub v1", "Injetado com sucesso!", 2)
    
    -- Animação: Faz o script aparecer vindo de baixo para o meio certinho
    MainFrame.Visible = true
    MainFrame:TweenPosition(UDim2.new(0.5, -275, 0.5, -175), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.6, true)
end)
