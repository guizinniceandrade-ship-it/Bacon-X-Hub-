local function AlternarAba(abaNome)
    for nome, componentes in pairs(AbasCriadas) do
        if nome == abaNome then
            componentes.Stroke.Color = Color3.fromRGB(255, 255, 255)
            componentes.Stroke.Thickness = 1.5
        else
            componentes.Stroke.Color = Color3.fromRGB(45, 45, 50)
            componentes.Stroke.Thickness = 1
        end
    end

    -- LIMPA TUDO AO TROCAR DE ABA
    for _, child in pairs(ContainerPaginas:GetChildren()) do
        if child:IsA("GuiObject") and child ~= GridBotoes then
            child:Destroy()
        end
    end

    -- CARREGA CONTEÚDO DA ABA SELECIONADA
    if abaNome == "Main" then
        CarregarConteudo_Main()
    elseif abaNome == "ESP" then
        CarregarConteudo_ESP()
    elseif abaNome == "Local Player" then
        CarregarConteudo_LocalPlayer()
    elseif abaNome == "Teleporte" then
        CarregarConteudo_Teleporte()
    end
end

