function CriarSlider(nomeAba, texto, min, max, padrao, funcao)
    local Card = Instance.new("Frame", paginas[nomeAba])
    Card.Size = UDim2.new(1, -10, 0, 52)
    Card.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", Card).Color = Color3.fromRGB(28, 28, 28)

    local Label = Instance.new("TextLabel", Card)
    Label.Text = "   " .. texto
    Label.Size = UDim2.new(0, 150, 0, 22)
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local ValLabel = Instance.new("TextLabel", Card)
    ValLabel.Text = tostring(padrao) .. "  "
    ValLabel.Position = UDim2.new(1, -60, 0, 0)
    ValLabel.Size = UDim2.new(0, 50, 0, 22)
    ValLabel.BackgroundTransparency = 1
    ValLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    ValLabel.Font = Enum.Font.GothamBold
    ValLabel.TextSize = 11
    ValLabel.TextXAlignment = Enum.TextXAlignment.Right

    local BaseLine = Instance.new("Frame", Card)
    BaseLine.Position = UDim2.new(0, 15, 0, 34)
    BaseLine.Size = UDim2.new(1, -30, 0, 4)
    BaseLine.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    Instance.new("UICorner", BaseLine).CornerRadius = UDim.new(1, 0)

    local ProgressLine = Instance.new("Frame", BaseLine)
    ProgressLine.Size = UDim2.new((padrao - min)/(max - min), 0, 1, 0)
    ProgressLine.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", ProgressLine).CornerRadius = UDim.new(1, 0)

    local SliderBall = Instance.new("Frame", ProgressLine)
    SliderBall.Size = UDim2.new(0, 10, 0, 10)
    SliderBall.Position = UDim2.new(1, -5, 0.5, -5)
    SliderBall.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", SliderBall).CornerRadius = UDim.new(1, 0)

    local segurando = false
    local function mover(input)
        local pos = math.clamp((input.Position.X - BaseLine.AbsolutePosition.X) / BaseLine.AbsoluteSize.X, 0, 1)
        ProgressLine.Size = UDim2.new(pos, 0, 1, 0)
        local realVal = math.floor(min + (pos * (max - min)))
        ValLabel.Text = tostring(realVal) .. "  "
        funcao(realVal)
    end

    BaseLine.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then segurando = true; mover(i) end end)
    UserInputService.InputChanged:Connect(function(i) if segurando and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then mover(i) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then segurando = false end end)
end

