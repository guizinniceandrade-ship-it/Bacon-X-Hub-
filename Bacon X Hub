local function CriarSom()
    local Som = Instance.new("Sound")
    Som.SoundId = "rbxassetid://116394299154002"
    Som.Volume = 1
    Som.Parent = SoundService
    return Som
end

local CliqueSound = CriarSom()
ContentProvider:PreloadAsync({CliqueSound})

local function TocarSom()
    if not CliqueSound or not CliqueSound.IsLoaded then
        CliqueSound = CriarSom()
        ContentProvider:PreloadAsync({CliqueSound})
        task.wait(0.05)
    end
    CliqueSound:Play()
end

-- ==========================================
-- [2] SISTEMA DE ESTRELAS DINÂMICAS
-- ==========================================
local function IniciarEstrelas(Parent)
    for i = 1, 35 do
        local Estrela = Instance.new("Frame", Parent)
        local tamanho = math.random(1, 3)
        Estrela.Size = UDim2.new(0, tamanho, 0, tamanho)
        Estrela.Position = UDim2.new(math.random(), 0, math.random(), 0)
        Estrela.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Estrela.BorderSizePixel = 0
        Estrela.BackgroundTransparency = math.random(2, 6) / 10
        Estrela.ZIndex = 1
        Instance.new("UICorner", Estrela).CornerRadius = UDim.new(1, 0)
        
        task.spawn(function()
            while Estrela.Parent do
                local tempo = math.random(6, 12)
                local novaPos = UDim2.new(math.random(), 0, math.random(), 0)
                local info = TweenInfo.new(tempo, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
                local tween = TweenService:Create(Estrela, info, {Position = novaPos})
                tween:Play()
                task.wait(tempo)
            end
        end)
    end
end

