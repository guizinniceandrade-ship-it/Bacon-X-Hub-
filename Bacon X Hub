local isFarming = false
local farmLoop = nil

-- Busca Universal de Moedas
local function FindAllCoins()
    local found = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:find("Coin") or v.Name:find("Token")) and v.Transparency < 1 then
            table.insert(found, v)
        end
    end
    return found
end

-- 3. MOTOR DE LÓGICA COM TRAVA DE SEGURANÇA (300 METROS)
AutoFarmToggle.MouseButton1Click:Connect(function()
    isFarming = not isFarming
    
    if isFarming then
        AutoFarmIndicator.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        AutoFarmToggle.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        farmLoop = task.spawn(function()
            while isFarming do
                task.wait(0.1) -- Varredura mais rápida para acompanhar o movimento liso
                
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                
                if root and hum and hum.Health > 0 then
                    local coins = FindAllCoins()
                    
                    if #coins > 0 then
                        local targetCoin = nil
                        local closestDistance = math.huge
                        
                        -- Encontra a moeda mais próxima
                        for _, part in ipairs(coins) do
                            local distance = (root.Position - part.Position).Magnitude
                            if distance < closestDistance then
                                closestDistance = distance
                                targetCoin = part
                            end
                        end
                        
                        if targetCoin then
                            pcall(function()
                                -- Noclip Total Ativo para não prender em portas/paredes ao deslizar
                                for _, bodyPart in pairs(char:GetDescendants()) do
                                    if bodyPart:IsA("BasePart") then bodyPart.CanCollide = false end
                                end
                                
                                -- Posição de coleta segura
                                local targetCFrame = targetCoin.CFrame * CFrame.new(0, 1.3, 0)
                                
                                -- [A SUA REGRA DE OURO AQUI]
                                if closestDistance > 300 then
                                    -- Teleporta APENAS se estiver extremamente longe (Mais de 300 metros)
                                    root.CFrame = targetCFrame
                                else
                                    -- Se estiver perto ou em salas normais, vai deslizando de forma veloz e segura
                                    -- Aumentamos a velocidade de deslize para 25 ou 20 para ir bem rápido sem dar kick
                                    local duration = closestDistance / 23
                                    local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
                                    tween:Play()
                                    task.wait(duration) -- Aguarda a conclusão do movimento seguro
                                end
                            end)
                        end
                    end
                end
            end
        end)
    else
        AutoFarmIndicator.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        AutoFarmToggle.TextColor3 = Color3.fromRGB(200, 200, 200)
        
        if farmLoop then
            task.cancel(farmLoop)
            farmLoop = nil
        end
    end
end)

