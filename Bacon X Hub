-- Função Principal do Tween (Modificada para destravar a física do boneco)
local function IniciarTweenVoando(posicaoDestino)
    local car = LocalPlayer.Character
    local hrp = car and car:FindFirstChild("HumanoidRootPart")
    local hum = car and car:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    -- Calcula a distância e o tempo de voo seguro
    local distancia = (hrp.Position - posicaoDestino).Magnitude
    local velocidade = 40 -- Velocidade do voo por Tween
    local tempoDeVoo = distancia / velocidade

    -- Destrava o estado do Humanoid e ancora temporariamente para não sofrer queda pela gravidade
    hrp.Anchored = true

    local infoTween = TweenInfo.new(tempoDeVoo, Enum.EasingStyle.Linear)
    local voo = TweenService:Create(hrp, infoTween, {CFrame = CFrame.new(posicaoDestino + Vector3.new(0, 3, 0))})
    
    CriarNotificacao("Teleporte", "Voando suavemente até o destino...", 2)
    voo:Play()
    
    -- Quando o voo terminar, devolve o controle físico ao jogador
    voo.Completed:Connect(function()
        hrp.Anchored = false
        CriarNotificacao("Teleporte", "Você chegou!", 1.5)
    end)
end

