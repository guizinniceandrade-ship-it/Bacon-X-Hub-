-- FUNÇÃO AUXILIAR: Cria os toggles modernos verdes
local function CriarToggleESP(texto, callback)
    local MainBtn = Instance.new("TextButton")
    local Corner = Instance.new("UICorner")
    local Stroke = Instance.new("UIStroke")
    
    MainBtn.Size = UDim2.new(1, -15, 0, 40)
    MainBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    MainBtn.Font = Enum.Font.GothamBold
    MainBtn.Text = "  " .. texto
    MainBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    MainBtn.TextSize = 14
    MainBtn.TextXAlignment = Enum.TextXAlignment.Left
    MainBtn.Parent = TargetPageESP
    
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = MainBtn
    Stroke.Thickness = 1; Stroke.Color = Color3.fromRGB(255, 255, 255); Stroke.Transparency = 0.92; Stroke.Parent = MainBtn
    
    local SwitchBg = Instance.new("Frame", MainBtn)
    SwitchBg.Size = UDim2.new(0, 34, 0, 18)
    SwitchBg.Position = UDim2.new(1, -44, 0.5, -9)
    SwitchBg.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Instance.new("UICorner", SwitchBg).CornerRadius = UDim.new(1, 0)
    
    local SwitchBall = Instance.new("Frame", SwitchBg)
    SwitchBall.Size = UDim2.new(0, 14, 0, 14)
    SwitchBall.Position = UDim2.new(0, 2, 0.5, -7)
    SwitchBall.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", SwitchBall).CornerRadius = UDim.new(1, 0)
    
    local ativo = false
    MainBtn.MouseButton1Click:Connect(function()
        ativo = not ativo
        local targetBgColor = ativo and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(45, 45, 45)
        local targetBallPos = ativo and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
        
        TweenService:Create(SwitchBg, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = targetBgColor}):Play()
        TweenService:Create(SwitchBall, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = targetBallPos}):Play()
        
        callback(ativo)
    end)
    return MainBtn
end

local function EnviarNotificacao(titulo, texto)
    StarterGui:SetCore("SendNotification", {
        Title = titulo,
        Text = texto,
        Duration = 5,
        Button1 = "OK"
    })
end

local function CriarDestaqueESP(objeto, corPadrao, tagIdentificacao)
    if not objeto then return end
    local idUnica = objeto:GetDebugId() .. "_" .. tagIdentificacao
    
    local Highlight = EspFolder:FindFirstChild(idUnica)
    if not Highlight then
        Highlight = Instance.new("Highlight")
        Highlight.Name = idUnica
        Highlight.Adornee = objeto
        Highlight.FillTransparency = 0.6
        Highlight.OutlineTransparency = 0.2
        Highlight.Parent = EspFolder
    end
    Highlight.FillColor = corPadrao
    Highlight.OutlineColor = corPadrao
end

local function LimparCategoriaESP(tagIdentificacao)
    for _, child in pairs(EspFolder:GetChildren()) do
        if string.find(child.Name, "_" .. tagIdentificacao) then
            child:Destroy()
        end
    end
end

