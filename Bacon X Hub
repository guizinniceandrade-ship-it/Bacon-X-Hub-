-- Função para atualizar a posição de TODAS as notificações ativas
local function AtualizarPosicoesNotificacoes()
    for indice, Notif in pairs(ListaDeNotificacoes) do
        if Notif and Notif.Frame then
            -- Calcula quanto essa notificação deve subir (cada uma fica 80px acima da próxima)
            local novaPosicao = UDim2.new(
                PosicaoInicial.X.Scale, 
                PosicaoInicial.X.Offset, 
                PosicaoInicial.Y.Scale, 
                PosicaoInicial.Y.Offset - ((indice - 1) * 85) -- 85px de espaço entre elas
            )
            -- Move suavemente para a posição correta
            TweenService:Create(Notif.Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = novaPosicao}):Play()
        end
    end
end

local function CriarNotificacao(tituloText, mensagemText, duracao)
    duracao = duracao or 3

    local NotifFrame = Instance.new("Frame", Screen)
    NotifFrame.Size = UDim2.new(0, 260, 0, 75)
    NotifFrame.Position = UDim2.new(1, 320, 1, -95) -- Começa fora da tela (direita)
    NotifFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    NotifFrame.ZIndex = 20
    Instance.new("UICorner", NotifFrame).CornerRadius = UDim.new(0, 8)
    
    local Stroke = Instance.new("UIStroke", NotifFrame)
    Stroke.Color = Color3.fromRGB(255, 255, 255)
    Stroke.Thickness = 1.5

    local T_Notif = Instance.new("TextLabel", NotifFrame)
    T_Notif.Size = UDim2.new(1, -20, 0, 28)
    T_Notif.Position = UDim2.new(0, 10, 0, 5)
    T_Notif.BackgroundTransparency = 1
    T_Notif.Font = Enum.Font.GothamBold
    T_Notif.Text = tituloText
    T_Notif.TextColor3 = Color3.fromRGB(255, 255, 255)
    T_Notif.TextSize = 15
    T_Notif.TextXAlignment = Enum.TextXAlignment.Left
    T_Notif.ZIndex = 21

    local M_Notif = Instance.new("TextLabel", NotifFrame)
    M_Notif.Size = UDim2.new(1, -20, 0, 38)
    M_Notif.Position = UDim2.new(0, 10, 0, 33)
    M_Notif.BackgroundTransparency = 1
    M_Notif.Font = Enum.Font.Gotham
    M_Notif.Text = mensagemText
    M_Notif.TextColor3 = Color3.fromRGB(180, 180, 180)
    M_Notif.TextSize = 12
    M_Notif.TextWrapped = true
    M_Notif.TextXAlignment = Enum.TextXAlignment.Left
    M_Notif.ZIndex = 21

    -- Adiciona essa notificação na lista
    local NovaNotif = {Frame = NotifFrame}
    table.insert(ListaDeNotificacoes, NovaNotif)

    -- Entra na tela suavemente
    TweenService:Create(NotifFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = PosicaoInicial}):Play()
    
    -- Atualiza a posição de todas para essa nova ficar embaixo
    AtualizarPosicoesNotificacoes()

    -- Função para remover a notificação
    local function RemoverNotificacao()
        if not NotifFrame or not NotifFrame.Parent then return end

        -- Remove da lista
        for i = #ListaDeNotificacoes, 1, -1 do
            if ListaDeNotificacoes[i] and ListaDeNotificacoes[i].Frame == NotifFrame then
                table.remove(ListaDeNotificacoes, i)
                break
            end
        end

        -- Animação de sair
        local Sair = TweenService:Create(NotifFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Position = UDim2.new(1, 320, 1, NotifFrame.Position.Y.Offset)})
        Sair:Play()
        Sair.Completed:Connect(function() 
            NotifFrame:Destroy() 
            -- Depois que sai, arruma a posição das que ficaram
            AtualizarPosicoesNotificacoes()
        end)
    end

    -- Começa a contagem para remover
    task.delay(duracao, RemoverNotificacao)
end

