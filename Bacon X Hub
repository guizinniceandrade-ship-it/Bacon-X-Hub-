-- ABA 3: LOCAL PLAYER
local function CarregarConteudo_LocalPlayer()
    CriarTituloPrincipal("MOVIMENTO DO PERSONAGEM")

    local speedLigado = false
    local velocidadeAtual = 16
    local jumpLigado = false
    -- ✅ Agora é em STUDs, exatamente como o MM2 usa
    local alturaPulo = 7 -- padrão do jogo é 7 studs
    local puloInfinitoLigado = false
    local noclipLigado = false

    CriarToggle("Speed", function(ligado)
        speedLigado = ligado
        local char = Player.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = ligado and velocidadeAtual or 16
            CriarNotificacao("Speed", ligado and "Ativado" or "Desativado", 2)
        end
    end)

    CriarSlider("Velocidade (Speed)", 16, 100, function(valor)
        velocidadeAtual = valor
        if speedLigado then
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = valor
            end
        end
    end)

    -- ✅ JUMP CORRIGIDO: AGORA FUNCIONA EM MM2!
    CriarToggle("Jump", function(ligado)
        jumpLigado = ligado
        local char = Player.Character
        if char and char:FindFirstChild("Humanoid") then
            -- No MM2, JumpHeight controla quantos STUDs pula
            char.Humanoid.JumpHeight = ligado and alturaPulo or 7
            -- Importante: também mudar o Power para pegar o valor certo
            char.Humanoid.JumpPower = ligado and (alturaPulo * 4.2) or 50
            CriarNotificacao("Jump", ligado and "Ativado | "..alturaPulo.." studs" or "Desativado", 2)
        end
    end)

    -- ✅ SLIDER DE STUDs: DE 7 ATÉ 300, FUNCIONANDO
    CriarSlider("Altura do Pulo (Studs)", 7, 300, function(valor)
        alturaPulo = valor
        -- Se o toggle estiver ligado, já aplica na hora
        if jumpLigado then
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.JumpHeight = valor
                char.Humanoid.JumpPower = valor * 4.2 -- cálculo correto para Roblox
            end
        end
    end)

    CriarToggle("Infinito Jump", function(ligado)
        puloInfinitoLigado = ligado
        CriarNotificacao("Infinito Jump", ligado and "Ativado" or "Desativado", 2)
    end)

    CriarToggle("Noclip", function(ligado)
        noclipLigado = ligado
        if ligado then
            task.spawn(function()
                while noclipLigado do
                    task.wait(0)
                    local char = Player.Character
                    if char then
                        for _, parte in pairs(char:GetChildren()) do
                            if parte:IsA("BasePart") then parte.CanCollide = false end
                        end
                    end
                end
                local char = Player.Character
                if char then
                    for _, parte in pairs(char:GetChildren()) do
                        if parte:IsA("BasePart") then parte.CanCollide = true end
                    end
                end
            end)
        end
    end)

    -- ✅ Pulo infinito também ajustado
    UserInputService.JumpRequest:Connect(function()
        if puloInfinitoLigado then
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                -- Mantém a altura que você escolheu
                if jumpLigado then
                    char.Humanoid.JumpHeight = alturaPulo
                    char.Humanoid.JumpPow = alturaPulo * 4.2
                end
            end
        end
    end)
end

