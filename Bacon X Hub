    local percentage = math.clamp((mousePos - barPos) / barWidth, 0, 1)
    
    SpeedSlideFill.Size = UDim2.new(percentage, 0, 1, 0)
    
    local calculatedValue = math.round(minSpeed + (percentage * (maxSpeed - minSpeed)))
    _G.WalkSpeedValue = calculatedValue
