-- ✅ Slider: barra e bolinha BRANCAS
local function CriarSlider(Nome, min, max, FuncaoAoAlterar)
    local SliderFrame = Instance.new("Frame", ContainerPaginas)
    SliderFrame.Size = UDim2.new(1, 0, 0, 46)
    SliderFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    SliderFrame.ZIndex = 6
    Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 6)

    local Stroke = Instance.new("UIStroke", SliderFrame)
    Stroke.Color = Color3.fromRGB(50, 50, 55)
    Stroke.Thickness = 1

    local Label = Instance.new("TextLabel", SliderFrame)
    Label.Size = UDim2.new(1, -20, 0, 20)
    Label.Position = UDim2.new(0, 12, 0, 5)
    Label.BackgroundTransparency = 1
    Label.Text = Nome..": "..min
    Label.Font = Enum.Font.Gotham
    Label.TextColor3 = Color3.fromRGB(255, 255, 255) -- TEXTO BRANCO
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.ZIndex = 7

    local Barra = Instance.new("Frame", SliderFrame)
    Barra.Size = UDim2.new(1, -24, 0, 6)
    Barra.Position = UDim2.new(0, 12, 0, 32)
    Barra.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    Barra.ZIndex = 7
    Instance.new("UICorner", Barra).CornerRadius = UDim.new(1, 0)

    local Preenchimento = Instance.new("Frame", Barra)
    Preenchimento.Size = UDim2.new(0, 0, 1, 0)
    Preenchimento.BackgroundColor3 = Color3.fromRGB(255, 255, 255) -- BRANCO
    Preenchimento.BorderSizePixel = 0
    Preenchimento.ZIndex = 8
    Instance.new("UICorner", Preenchimento).CornerRadius = UDim.new(1, 0)

    local BolinhaBranca = Instance.new("Frame", Barra)
    BolinhaBranca.Size = UDim2.new(0, 14, 0, 14)
    BolinhaBranca.Position = UDim2.new(0, -7, 0.5, -7)
    BolinhaBranca.BackgroundColor3 = Color3.fromRGB(255, 255, 255) -- BOLINHA BRANCA
    BolinhaBranca.ZIndex = 9
    Instance.new("UICorner", BolinhaBranca).CornerRadius = UDim.new(1, 0)

    local arrastando = false
    local function Atualizar(input)
        local posBarra = Barra.AbsolutePosition.X
        local tamBarra = Barra.AbsoluteSize.X
        local porcentagem = math.clamp((input.Position.X - posBarra) / tamBarra, 0, 1)
        
        Preenchimento.Size = UDim2.new(porcentagem, 0, 1, 0)
        BolinhaBranca.Position = UDim2.new(porcentagem, -7, 0.5, -7)
        
        local valor = math.floor(min + (max - min) * porcentagem)
        Label.Text = Nome..": "..valor
        FuncaoAoAlterar(valor)
    end

    Barra.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            TocarSom()
            arrastando = true
            Atualizar(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if arrastando and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            Atualizar(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            arrastando = false
        end
    end)
end

