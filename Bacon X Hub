local function CriarSliderBesta(texto, min, max, callback)
    local SliderFrame = Instance.new("Frame")
    local SliderCorner = Instance.new("UICorner")
    local SliderStroke = Instance.new("UIStroke")
    local SliderText = Instance.new("TextLabel")
    local SliderBar = Instance.new("Frame")
    local SliderFill = Instance.new("Frame")
    local SliderBtn = Instance.new("ImageButton")
    
    SliderFrame.Size = UDim2.new(1, -15, 0, 45)
    SliderFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    SliderFrame.Parent = TargetPageMain
    
    SliderCorner.CornerRadius = UDim.new(0, 6)
    SliderCorner.Parent = SliderFrame
    
    SliderStroke.Thickness = 1
    SliderStroke.Color = Color3.fromRGB(255, 255, 255)
    SliderStroke.Transparency = 0.92
    SliderStroke.Parent = SliderFrame
    
    SliderText.Size = UDim2.new(1, -20, 0, 20)
    SliderText.Position = UDim2.new(0, 10, 0, 4)
    SliderText.BackgroundTransparency = 1
    SliderText.Font = Enum.Font.GothamBold
    SliderText.Text = texto .. ": " .. min
    SliderText.TextColor3 = Color3.fromRGB(255, 255, 255)
    SliderText.TextSize = 13
    SliderText.TextXAlignment = Enum.TextXAlignment.Left
    SliderText.Parent = SliderFrame
    
    -- Barra de progresso principal (tornada mais grossa e descida um pouco)
    SliderBar.Size = UDim2.new(1, -20, 0, 6)
    SliderBar.Position = UDim2.new(0, 10, 0, 28)
    SliderBar.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    SliderBar.Parent = SliderFrame
    Instance.new("UICorner", SliderBar).CornerRadius = UDim.new(1, 0)
    
    SliderFill.Size = UDim2.new(0, 0, 1, 0)
    SliderFill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    SliderFill.Parent = SliderBar
    Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)
    
    -- O Botão indicador agora é Azul, maior e flutua corretamente sobre a barra
    SliderBtn.Size = UDim2.new(0, 14, 0, 14)
    SliderBtn.Position = UDim2.new(1, -7, 0.5, -7)
    SliderBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    SliderBtn.ZIndex = 3
    SliderBtn.Parent = SliderFill
    Instance.new("UICorner", SliderBtn).CornerRadius = UDim.new(1, 0)
    
    local mouse = game:GetService("Players").LocalPlayer:GetMouse()
    local segurando = false
    
    local function AtualizarSlider()
        local percent = math.clamp((mouse.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
        SliderFill.Size = UDim2.new(percent, 0, 1, 0)
        local valorFinal = math.floor(min + (max - min) * percent)
        SliderText.Text = texto .. ": " .. valorFinal
        callback(valorFinal)
    end
    
    SliderBtn.MouseButton1Down:Connect(function() segurando = true end)
    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then segurando = false end
    end)
    
    mouse.Move:Connect(function()
        if segurando then AtualizarSlider() end
    end)
end

