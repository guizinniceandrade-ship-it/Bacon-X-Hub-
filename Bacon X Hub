game:GetService("RunService").RenderStepped:Connect(function()
    local Player = game:GetService("Players").LocalPlayer
    
    if hitboxBestaAtiva then
        for _, p in pairs(game:GetService("Players"):GetPlayers()) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("Head") then
                local head = p.Character.Head
                head.Size = Vector3.new(tamanhoHitbox, tamanhoHitbox, tamanhoHitbox)
                head.CanCollide = false
                head.Transparency = 0.5
            end
        end
    end
    
    if Player.Character then
        local martelo = Player.Character:FindFirstChild("Hammer") or Player.Backpack:FindFirstChild("Hammer")
        if martelo then
            if semDelayMartelo then
                local cd1 = martelo:FindFirstChild("Cooldown")
                local cd2 = martelo:FindFirstChild("Rate")
                if cd1 then cd1.Value = 0 end
                if cd2 then cd2.Value = 0 end
                martelo:SetAttribute("Cooldown", 0)
                martelo:SetAttribute("AttackDelay", 0)
            end
            if semBrilhoMartelo then
                for _, ef in pairs(martelo:GetDescendants()) do
                    if ef:IsA("Light") or ef:IsA("ParticleEmitter") or ef:IsA("Trail") then
                        ef.Enabled = false
                    end
                end
            end
        end
    end
    
    if semMusicaAtivo then
        for _, som in pairs(game:GetService("SoundService"):GetDescendants()) do
            if som:IsA("Sound") and (string.find(string.lower(som.Name), "beast") or string.find(string.lower(som.Name), "chase") or string.find(string.lower(som.Name), "terror")) then
                som.Volume = 0
            end
        end
    end
end)



