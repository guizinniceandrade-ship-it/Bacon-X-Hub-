ContentContainer.Parent = MainFrame
ContentContainer.Position = UDim2.new(0, 140, 0, 40)
ContentContainer.Size = UDim2.new(1, -145, 1, -45)
ContentContainer.BackgroundTransparency = 1

-- =============================================================================
-- SISTEMA GERENCIADOR DE ABAS DINÂMICO
-- =============================================================================
local abas = {
    "Murderer",
    "Sherif",
    "Inocente",
    "Esp",
    "Auto Farm",
    "Local player",
    "Estatus do servidor",
    "Senttings",
    "Misc",
    "Perfil"
}

local paginas = {}
local primeiroBotao = nil

for i, nomeAba in ipairs(abas) do
    -- 1. Cria a Página de Conteúdo com Rolagem independente para a aba
    local PaginaScroll = Instance.new("ScrollingFrame")
    PaginaScroll.Name = nomeAba .. "Page"
    PaginaScroll.Parent = ContentContainer
    PaginaScroll.Size = UDim2.new(1, 0, 1, 0)
    PaginaScroll.BackgroundTransparency = 1
    PaginaScroll.Visible = false
    PaginaScroll.CanvasSize = UDim2.new(0, 0, 0, 0) -- Ajusta via script conforme adicionar botões
    PaginaScroll.ScrollBarThickness = 3
    PaginaScroll.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 60)
    
    local PaginaList = Instance.new("UIListLayout")
    PaginaList.Parent = PaginaScroll
    PaginaList.SortOrder = Enum.SortOrder.LayoutOrder
    PaginaList.Padding = UDim.new(0, 6)
    
    -- Auto-ajuste do tamanho da rolagem interna da página
    PaginaList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        PaginaScroll.CanvasSize = UDim2.new(0, 0, 0, PaginaList.AbsoluteContentSize.Y + 15)
    end)
    
    paginas[nomeAba] = PaginaScroll

    -- 2. Cria o Botão correspondente no Menu Lateral
    local BotaoAba = Instance.new("TextButton")
    BotaoAba.Name = nomeAba .. "Btn"
    BotaoAba.Parent = NavigationScroll
    BotaoAba.Size = UDim2.new(1, -5, 0, 32)
    BotaoAba.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    BotaoAba.Font = Enum.Font.GothamBold
    BotaoAba.Text = "  " .. nomeAba
    BotaoAba.TextColor3 = Color3.fromRGB(160, 160, 160)
    BotaoAba.TextSize = 11
    BotaoAba.TextXAlignment = Enum.TextXAlignment.Left
    BotaoAba.LayoutOrder = i
    
    local BotaoCorner = Instance.new("UICorner")
    BotaoCorner.CornerRadius = UDim.new(0, 4)
    BotaoCorner.Parent = BotaoAba

    -- Troca de abas ao clicar
    BotaoAba.MouseButton1Click:Connect(function()
        -- Reseta todos os botões e páginas
        for _, nome in pairs(abas) do
            paginas[nome].Visible = false
            local btn = NavigationScroll:FindFirstChild(nome .. "Btn")
            if btn then
                btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                btn.TextColor3 = Color3.fromRGB(160, 160, 160)
            end
        end
        -- Ativa a aba clicada (Visual Cinza Claro/Branco ao selecionar)
        PaginaScroll.Visible = true
        BotaoAba.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        BotaoAba.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    
    if i == 1 then primeiroBotao = BotaoAba end
end

-- Ativa a primeira aba por padrão ao executar
if primeiroBotao then
    primeiroBotao.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    primeiroBotao.TextColor3 = Color3.fromRGB(255, 255, 255)
    paginas[abas[1]].Visible = true
end

-- Ajusta o tamanho da rolagem do Menu Lateral baseado no número de abas
NavList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    NavigationScroll.CanvasSize = UDim2.new(0, 0, 0, NavList.AbsoluteContentSize.Y + 10)
end)

-- =============================================================================
-- SISTEMA DE ARRASTAR A JANELA (Mobile Draggable)
-- =============================================================================
local dragging, dragInput, dragStart, startPos
TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
TopBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Atalho para abrir/fechar via teclado (Teclados Físicos / PC)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.Insert then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

-- =============================================================================
-- SISTEMA DE NOTIFICAÇÕES (RODA EM SEGUNDO PLANO)
-- =============================================================================
local function CriarNotificacao(titulo, mensagem, duracaoExibicao)
    -- Cria um container invisível para a notificação na base da tela
    local NotifFrame = Instance.new("Frame")
    NotifFrame.Name = "BaconNotification"
    NotifFrame.Parent = ScreenGui -- Usa a mesma ScreenGui do Hub
    NotifFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15) -- Fundo escuro clean
    NotifFrame.Size = UDim2.new(0, 280, 0, 65)
    -- Começa um pouco abaixo da tela (escondido) para fazer o efeito de subida
    NotifFrame.Position = UDim2.new(0.5, -140, 1, 20)
    
    local NotifCorner = Instance.new("UICorner")
    NotifCorner.CornerRadius = UDim.new(0, 5)
    NotifCorner.Parent = NotifFrame
    
    -- Título da Notificação (Bacon X Hub)
    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Parent = NotifFrame
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Position = UDim2.new(0, 10, 0, 6)
    TitleLabel.Size = UDim2.new(1, -20, 0, 15)
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.Text = titulo
    TitleLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
    TitleLabel.TextSize = 13
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Mensagem de texto
    local MsgLabel = Instance.new("TextLabel")
    MsgLabel.Parent = NotifFrame
    MsgLabel.BackgroundTransparency = 1
    MsgLabel.Position = UDim2.new(0, 10, 0, 24)
    MsgLabel.Size = UDim2.new(1, -20, 0, 35)
    MsgLabel.Font = Enum.Font.Gotham
    MsgLabel.Text = mensagem
    MsgLabel.TextColor3 = Color3.fromRGB(170, 170, 170)
    MsgLabel.TextSize = 11
    MsgLabel.TextXAlignment = Enum.TextXAlignment.Left
    MsgLabel.TextYAlignment = Enum.TextYAlignment.Top
    MsgLabel.TextWrapped = true

    -- Efeito de Subida (Aparecer)
    NotifFrame:TweenPosition(
        UDim2.new(0.5, -140, 1, -85), -- Sobe para ficar visível perto do rodapé
        Enum.EasingDirection.Out,
        Enum.EasingStyle.Quart,
        0.5,
        true
    )
    
    -- Tempo que ela fica na tela antes de sumir
    task.wait(duracaoExibicao)
    
    -- Efeito de Descida (Sumir)
    NotifFrame:TweenPosition(
        UDim2.new(0.5, -140, 1, 20), -- Desce para fora da tela de novo
        Enum.EasingDirection.In,
        Enum.EasingStyle.Quart,
        0.5,
        true
    )
    
    task.wait(0.5)
    NotifFrame:Destroy()
end

-- Sequência de tempo exata que você pediu
task.spawn(function()
    -- 1ª Notificação (Aparece na hora)
    CriarNotificacao("Bacon X Hub", "Bem vindo ao meu script de MM2 espero que se divirta.", 3.5)
    
    -- Espera dar os 4 segundos no total
    task.wait(0.5) 
    
    -- 2ª Notificação (Após 4 segundos)
    CriarNotificacao("Bacon X Hub", "Script está carregando por favor espere...", 3.5)
    
    -- Espera dar os 7 segundos desde a anterior
    task.wait(3.5)
    
    -- 3ª Notificação (Após 7 segundos)
    CriarNotificacao("Bacon X Hub", "Script carregado com sucesso.", 4)
end)

