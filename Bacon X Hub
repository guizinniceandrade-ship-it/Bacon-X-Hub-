    btn.TextSize = 12
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25) -- COR DE FUNDO FIXA, NÃO MUDA
    btn.BackgroundTransparency = 0.3
    btn.ZIndex = 6
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    -- ⚠️ BORDA QUE SÓ APARECE QUANDO SELECIONADO
    local BtnStroke = Instance.new("UIStroke", btn)
    BtnStroke.Color = Color3.fromRGB(255, 255, 255) -- SEMPRE BRANCA
    BtnStroke.Thickness = 1.5
    BtnStroke.Enabled = false -- COMEÇA DESATIVADA
    BtnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    AbasCriadas[nome] = {Botao = btn, Stroke = BtnStroke}

    btn.MouseButton1Click:Connect(function() TocarSom() AlternarAba(nome) end)
end

