-- 4. MOTOR LÓGICO UNIFICADO (PRECISÃO MÁXIMA)
task.spawn(function()
    while true do
        task.wait(0.5)
        
        local computadoresNoMapa = {}
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj.Name == "ComputerTable" and obj:IsA("Model") then
                table.insert(computadoresNoMapa, obj)
            end
        end
        
        if #computadoresNoMapa == 0 then
            bestaAvisada = false
            ultimoPcCount = 5
            LimparCategoriaESP("Comp")
            LimparCategoriaESP("Tube")
            LimparCategoriaESP("Exit")
        else
            -- [MOTOR COMPUTADORES]
            if espComputadorAtivo then
                for _, comp in pairs(computadoresNoMapa) do
                    local corComp = Color3.fromRGB(0, 170, 255)
                    local screen = comp:FindFirstChild("Screen", true)
                    if screen and screen:IsA("BasePart") then
                        if screen.BrickColor.Name == "Lime green" or screen.BrickColor.Name == "Dark green" or (screen.Color.G > 0.6 and screen.Color.R < 0.3) then
                            corComp = Color3.fromRGB(0, 255, 0)
                        end
                    end
                    CriarDestaqueESP(comp, corComp, "Comp")
                end
            end
            
            -- [MOTOR CÁPSULAS] (Correção do print: Pega o modelo FreezePod inteiro diretamente)
            if espCapsulasAtivo then
                for _, obj in pairs(Workspace:GetDescendants()) do
                    if (obj.Name == "FreezePod" or obj.Name == "Tube") and obj:IsA("Model") then
                        CriarDestaqueESP(obj, Color3.fromRGB(255, 165, 0), "Tube")
                    end
                end
            end
            
            -- [MOTOR PORTÃO DE SAÍDA REAL] (Filtro anti-bug para ignorar portas normais)
            if espPortaoAtivo then
                for _, obj in pairs(Workspace:GetDescendants()) do
                    if obj:IsA("Model") and (obj.Name == "ExitGate" or obj.Name == "ExitDoor" or obj.Parent.Name == "FourEconGates") then
                        -- Se tiver uma peça chamada "Panel" ou "Door" e NÃO for uma porta comum de corredor
                        if obj:FindFirstChild("Panel") or obj:FindFirstChild("Door") or obj:FindFirstChild("Gate") then
                            if not obj:FindFirstChild("DoorFrame") then -- Portas comuns usam DoorFrame no FtF
                                CriarDestaqueESP(obj, Color3.fromRGB(255, 255, 0), "Exit")
                            end
                        end
                    end
                end
            end
            
            -- [MOTOR PLAYERS]
            if espPlayerAtivo then
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local char = p.Character
                        local ehBesta = (char:FindFirstChild("Hammer") or p.Backpack:FindFirstChild("Hammer") or char:FindFirstChild("Weapon")) and true or false
                        local corPlayer = ehBesta and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 100)
                        CriarDestaqueESP(char, corPlayer, "Player")
                    end
                end
            end
            
            -- [NOTIFICAÇÃO DE BESTA]
            if notifBestaAtivo and not bestaAvisada then
                for _, p in pairs(Players:GetPlayers()) do
                    if p.Character and (p.Character:FindFirstChild("Hammer") or p.Backpack:FindFirstChild("Hammer")) then
                        EnviarNotificacao("👹 BESTA DETECTADA", "A Besta da rodada é: " .. p.Name)
                        bestaAvisada = true
                        break
                    end
                end
            end
            
            -- [NOTIFICAÇÃO DE QUANTOS PC]
            if notifPcAtivo then
                local pcsRestantes = 0
                for _, comp in pairs(computadoresNoMapa) do
                    local screen = comp:FindFirstChild("Screen", true)
                    local jaHackeado = false
                    if screen and screen:IsA("BasePart") then
                        if screen.BrickColor.Name == "Lime green" or screen.BrickColor.Name == "Dark green" or (screen.Color.G > 0.6 and screen.Color.R < 0.3) then
                            jaHackeado = true
                        end
                    end
                    if not jaHackeado then pcsRestantes = pcsRestantes + 1 end
                end
                
                if pcsRestantes < ultimoPcCount and pcsRestantes >= 0 then
                    ultimoPcCount = pcsRestantes
                    if pcsRestantes == 0 then
                        EnviarNotificacao("⚡ SINAL ENERGIZADO", "Todos os PCs concluídos! Portões abertos!")
                    else
                        EnviarNotificacao("💻 PC HACKEADO", "Faltam apenas " .. pcsRestantes .. " computadores.")
                    end
                end
            end
            
        end
    end
end)
