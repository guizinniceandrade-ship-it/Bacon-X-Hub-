-- =============================================================================
-- MOTOR DE LÓGICA: AUTO FARM DE MOEDAS (VERSÃO ULTRA OTIMIZADA)
-- =============================================================================
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

task.spawn(function()
    while task.wait(0.2) do
        -- Corrigido para LocalPlayer e checagem de vida
        if _G.AutoFarmMoedas and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local root = LocalPlayer.Character.HumanoidRootPart
                local target, minDist = nil, math.huge
                
                -- Busca a moeda válida mais próxima no mapa
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("BasePart") and (v.Name:find("Coin") or v.Name:find("Token")) and v.Transparency < 1 then
                        local d = (root.Position - v.Position).Magnitude
                        if d < minDist then 
                            minDist = d
                            target = v 
                        end
                    end
                end
                
                if target then
                    -- Ativa noclip temporário para não bater nas paredes durante o deslize
                    for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanCollide = false end
                    end
                    
                    -- Se a moeda estiver muito longe (ex: nasceu no andar de cima), teleporta direto
                    if minDist > 35 then 
                        root.CFrame = target.CFrame * CFrame.new(0, 1, 0)
                    else
                        -- Se estiver perto, vai deslizando rápido (Velocidade ajustada: 38)
                        local tween = TweenService:Create(root, TweenInfo.new(minDist/38, Enum.EasingStyle.Linear), {CFrame = target.CFrame})
                        tween:Play()
                    end
                end
            end)
        end
    end
end)
