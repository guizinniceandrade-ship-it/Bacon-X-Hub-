    tTitle.TextXAlignment = Enum.TextXAlignment.Left
    tTitle.Text = titulo

    local tMsg = Instance.new("TextLabel", NotifFrame)
    tMsg.Size = UDim2.new(1, -24, 0, 35)
    tMsg.Position = UDim2.new(0, 12, 0, 28)
    tMsg.BackgroundTransparency = 1
    tMsg.Font = Enum.Font.GothamMedium
    tMsg.TextColor3 = Color3.fromRGB(220, 220, 220)
    tMsg.TextSize = 11
    tMsg.TextXAlignment = Enum.TextXAlignment.Left
    tMsg.TextWrapped = true
    tMsg.Text = mensagem

    TweenService:Create(NotifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -280, 1, -85)}):Play()
    
    task.delay(duracao, function()
        local s = TweenService:Create(NotifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(1, 300, 1, -85)})
        s:Play()
