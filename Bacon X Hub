-- 3. LÓGICA DO TELEPORTE: PORTÃO (COM RECUO)
CriarLinhaTeleporte("Teleporte portão", function()
    local portoes = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if (obj.Name == "ExitGate" or obj.Name:match("Gate") or obj.Name:match("Exit")) and obj:IsA("Model") then
            table.insert(portoes, obj)
        end
    end

    if #portoes > 0 then
        local portaoEscolhido = portoes[math.random(1, #portoes)]
        local primPart = portaoEscolhido.PrimaryPart or portaoEscolhido:FindFirstChildOfClass("Part")
        if primPart then
            -- Portões são muito grandes, damos um offset um pouco maior para garantir que não vai bugar na parede
