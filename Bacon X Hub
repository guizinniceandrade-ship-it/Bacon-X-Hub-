-- PARTE 4: SISTEMA DE ALTERNAÇÃO DE ABAS COM ANIMAÇÃO
-- =============================================================================
local currentTab = "Main"

local function switchTab(targetTab)
    if currentTab == targetTab then return end
    
    for name, page in pairs(tabPages) do
        local btn = tabButtons[name]
        if name == targetTab then
            page.Visible = true
            TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(25, 25, 25), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        else
            page.Visible = false
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(15, 15, 15), TextColor3 = Color3.fromRGB(150, 150, 150)}):Play()
        end
    end
    currentTab = targetTab
end

for name, btn in pairs(tabButtons) do
    btn.MouseButton1Click:Connect(function()
        switchTab(name)
    end)
end

