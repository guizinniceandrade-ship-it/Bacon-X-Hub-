-- Arrastar painel principal e botão flutuante
local segurandoFrame, clickStart, frameStart
TopBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then segurandoFrame = true; clickStart = i.Position; frameStart = MainFrame.Position end end)
UserInputService.InputChanged:Connect(function(i) if segurandoFrame and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then local diff = i.Position - clickStart; MainFrame.Position = frameStart + UDim2.new(0, diff.X, 0, diff.Y) end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then segurandoFrame = false end end)

local segurandoBXH, clickStartBXH, bxhStart
OpenBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then segurandoBXH = true; clickStartBXH = i.Position; bxhStart = OpenBtn.Position end end)
UserInputService.InputChanged:Connect(function(i) if segurandoBXH and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then local diff = i.Position - clickStartBXH; OpenBtn.Position = bxhStart + UDim2.new(0, diff.X, 0, diff.Y) end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then segurandoBXH = false end end)

-- =============================================================================
-- SISTEMA DE NOTIFICAÇÕES EM SEQUÊNCIA (Boas-vindas / Carregamento)
-- =============================================================================
local function MostrarNotificacao(titulo, mensagem, duracao)
    local NotifFrame = Instance.new("Frame", ScreenGui)
    NotifFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    NotifFrame.Size = UDim2.new(0, 260, 0, 60)
    NotifFrame.Position = UDim2.new(1, 30, 1, -90) -- Inicia escondido na direita
    Instance.new("UICorner", NotifFrame).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", NotifFrame).Color = Color3.fromRGB(35, 35, 35)
    
    local TxtTitle = Instance.new("TextLabel", NotifFrame)
    TxtTitle.Text = "  " .. titulo
    TxtTitle.Size = UDim2.new(1, -10, 0, 22)
    TxtTitle.Position = UDim2.new(0, 5, 0, 4)
    TxtTitle.BackgroundTransparency = 1
    TxtTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    TxtTitle.Font = Enum.Font.GothamBold
    TxtTitle.TextSize = 12
    TxtTitle.TextXAlignment = Enum.TextXAlignment.Left
    
    local TxtMsg = Instance.new("TextLabel", NotifFrame)
    TxtMsg.Text = "  " .. mensagem
    TxtMsg.Size = UDim2.new(1, -10, 0, 28)
    TxtMsg.Position = UDim2.new(0, 5, 0, 24)
    TxtMsg.BackgroundTransparency = 1
    TxtMsg.TextColor3 = Color3.fromRGB(150, 150, 150)
    TxtMsg.Font = Enum.Font.Gotham
    TxtMsg.TextSize = 10
    TxtMsg.TextXAlignment = Enum.TextXAlignment.Left
    TxtMsg.TextWrapped = true

    -- Animação de Entrada
    NotifFrame:TweenPosition(UDim2.new(1, -280, 1, -90), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.4, true)
    task.wait(duracao)
    
    -- Animação de Saída
    NotifFrame:TweenPosition(UDim2.new(1, 30, 1, -90), Enum.EasingDirection.In, Enum.EasingStyle.Quart, 0.4, true)
    task.wait(0.4)
    NotifFrame:Destroy()
end

-- Thread gerenciadora do carregamento sequencial
task.spawn(function()
    MostrarNotificacao("Bacon X Hub", "Seja muito bem vindo ao meu script de MM2", 2.5)
    task.wait(0.2)
    
    MostrarNotificacao("Bacon X Hub", "Script está carregando por favor espere...", 2.5)
    task.wait(0.2)
    
    task.spawn(function()
        MostrarNotificacao("Bacon X Hub", "Script carregado com sucesso espero que goste", 3)
    end)
    
    MainFrame.Visible = true
    MainFrame:TweenPosition(UDim2.new(0.5, -275, 0.5, -175), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.5, true)
end)
