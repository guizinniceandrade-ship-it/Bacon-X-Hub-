    local SliderStroke = Instance.new("UIStroke", SliderFrame)
    SliderStroke.Color = Color3.fromRGB(35, 35, 35)

    local Label = Instance.new("TextLabel", SliderFrame)
    Label.Size = UDim2.new(1, -80, 0, 20)
    Label.Position = UDim2.new(0, 12, 0, 5)
    Label.BackgroundTransparency = 1
    Label.Font = Enum.Font.GothamMedium
    Label.Text = textoNome
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.TextSize = 11
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local ValorLabel = Instance.new("TextLabel", SliderFrame)
    ValorLabel.Size = UDim2.new(0, 60, 0, 20)
    ValorLabel.Position = UDim2.new(1, -72, 0, 5)
    ValorLabel.BackgroundTransparency = 1
    ValorLabel.Font = Enum.Font.GothamBold
    ValorLabel.Text = tostring(valorPadrao)
    ValorLabel.TextColor3 = Color3.fromRGB(0, 200, 100)
    ValorLabel.TextSize = 12
    ValorLabel.TextXAlignment = Enum.TextXAlignment.Right

    local SliderBarBg = Instance.new("TextButton", SliderFrame)
    SliderBarBg.Size = UDim2.new(1, -24, 0, 6)
    SliderBarBg.Position = UDim2.new(0, 12, 0, 32)
    SliderBarBg.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    SliderBarBg.Text = ""
    Instance.new("UICorner", SliderBarBg)

    local SliderBarFill = Instance.new("Frame", SliderBarBg)
    local proporcaoPadrao = (valorPadrao - valorMin) / (valorMax - valorMin)
    SliderBarFill.Size = UDim2.new(proporcaoPadrao, 0, 1, 0)
    SliderBarFill.BackgroundColor3 = Color3.fromRGB(0, 180, 90)
    Instance.new("UICorner", SliderBarFill)

    local SliderBtn = Instance.new("Frame", SliderBarFill)
    SliderBtn.Size = UDim2.new(0, 14, 0, 14)
    SliderBtn.Position = UDim2.new(1, -7, 0.5, -7)
    SliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", SliderBtn)
    Instance.new("UIStroke", SliderBtn).Color = Color3.fromRGB(0, 255, 130)

    local arrastando = false

    local function AtualizarSlider(input)
        local delta = input.Position.X - SliderBarBg.AbsolutePosition.X
        local porcentagem = math.clamp(delta / SliderBarBg.AbsoluteSize.X, 0, 1)
        
        SliderBarFill.Size = UDim2.new(porcentagem, 0, 1, 0)
        
        local valorFinal = math.floor(valorMin + (porcentagem * (valorMax - valorMin)))
        ValorLabel.Text = tostring(valorFinal)
        funcaoCallback(valorFinal)
    end

    SliderBarBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            arrastando = true
            AtualizarSlider(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if arrastando and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            AtualizarSlider(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            arrastando = false
        end
    end)
end

