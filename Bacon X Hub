-- Valores de limite do alcance da faca
local minDistance = 5
local maxDistance = 30
_G.KillAuraRange = 15

-- Lógica para arrastar e ajustar no celular de forma suave
local UserInputService = game:GetService("UserInputService")
local sliding = false

local function updateSlider(input)
    local mousePos = input.Position.X
    local barPos = SlideBarMain.AbsolutePosition.X
    local barWidth = SlideBarMain.AbsoluteSize.X
    local percentage = math.clamp((mousePos - barPos) / barWidth, 0, 1)
    
    SlideFill.Size = UDim2.new(percentage, 0, 1, 0)
    
    local calculatedValue = math.round(minDistance + (percentage * (maxDistance - minDistance)))
    _G.KillAuraRange = calculatedValue
    SliderValue.Text = tostring(calculatedValue) .. " studs"
end

SlideBarMain.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        sliding = true
        updateSlider(input)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateSlider(input)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        sliding = false
    end
end)

