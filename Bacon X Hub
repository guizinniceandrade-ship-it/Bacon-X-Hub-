-- [5] CONFIGURAÇÃO DO CONTEÚDO DE CADA ABA
-- =============================================================================
local AutoFarmAtivo = false
local VelocidadeFarm = 16 

local function CarregarConteudo_Main()
    CriarTextoTitulo("Auto Farm")
    
    CriarToggleScript("Farm Coin", function(estado)
        AutoFarmAtivo = estado
        
        if AutoFarmAtivo then
            task.spawn(function()
                while AutoFarmAtivo do
                    task.wait(0.1)
                    pcall(function()
                        local ContainerMoedas = workspace:FindFirstChild("Normal") and workspace.Normal:FindFirstChild("CoinContainer")
                        local Char = Player.Character
                        local Root = Char and Char:FindFirstChild("HumanoidRootPart")
                        
                        if Root and ContainerMoedas then
                            for _, moeda in pairs(ContainerMoedas:GetChildren()) do
                                if not AutoFarmAtivo then break end
                                
                                if moeda:IsA("BasePart") and moeda.Transparency < 1 then
                                    while AutoFarmAtivo and moeda.Parent and Root do
                                        local distancia = (moeda.Position - Root.Position).Magnitude
                                        if distancia < 3 then
                                            Root.CFrame = moeda.CFrame
                                            break
                                        else
                                            -- Interpolação suave simulando velocidade controlável pelo Slider
                                            Root.CFrame = Root.CFrame:Lerp(CFrame.new(moeda.Position), (VelocidadeFarm / 100))
                                        end
                                        task.wait()
                                    end
                                end
                            end
                        end
                    end)
                end
            end)
        end
    end)
    
    CriarSliderScript("Velocidade do Farm", 16, 50, function(valor)
        VelocidadeFarm = valor
        pcall(function()
            if Player.Character and Player.Character:FindFirstChild("Humanoid") then
                Player.Character.Humanoid.WalkSpeed = valor
            end
        end)
    end)
end

