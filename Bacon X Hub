    local tTitle = Instance.new("TextLabel", NotifFrame)
    tTitle.Size = UDim2.new(1, -20, 0, 25)
    tTitle.Position = UDim2.new(0, 12, 0, 6)
    tTitle.BackgroundTransparency = 1
