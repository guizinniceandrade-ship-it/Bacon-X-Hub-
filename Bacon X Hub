    SliderBar.Size = UDim2.new(1, -20, 0, 7)
    SliderBar.Position = UDim2.new(0, 10, 0.7, -3.5)
    SliderBar.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    SliderBar.Text = ""
    SliderBar.ZIndex = 7
    SliderBar.AutoButtonColor = false
    Instance.new("UICorner", SliderBar).CornerRadius = UDim.new(1, 0)
    
    local SliderFill = Instance.new("Frame", SliderBar)
    SliderFill.Size = UDim2.new(0, 0, 1, 0)
    SliderFill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    SliderFill.BorderSizePixel = 0
    SliderFill.ZIndex = 8
    Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)
    
    local arrastando = false
    local function AtualizarSlider(input)
        local barPos = SliderBar.AbsolutePosition.X
        local barTam = SliderBar.AbsoluteSize.X
        local posX = math.clamp((input.Position.X - barPos) / barTam, 0, 1)
        SliderFill.Size = UDim2.new(posX, 0, 1, 0)
        local valorFinal = math.floor(min + (max - min) * posX)
        Label.Text = nomeSlider .. ": " .. tostring(valorFinal)
        funcaoCallback(valorFinal)
    end
    
    SliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            TocarSom() 
            arrastando = true
            AtualizarSlider(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if arrastando and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            AtualizarSlider(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            arrastando = false
        end
    end)
end

