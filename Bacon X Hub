-- VARIÁVEIS GLOBAIS DE CONTROLE
_G.AutoFarmTweenAtivado = false
_G.AutoFarmSpeed = 15
_G.AutoFarmPosicaoYAtivado = false

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

-- =============================================================================
-- MOTOR DO AUTO FARM RECONFIGURADO
-- =============================================================================
local function FindAllCoins()
    local found = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:find("Coin") or v.Name:find("Token")) and v.Transparency < 1 then
            table.insert(found, v)
        end
    end
    return found
end

task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoFarmTweenAtivado then
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            if root and hum and hum.Health > 0 then
                local coins = FindAllCoins()
                
                if #coins > 0 then
                    local targetCoin = nil
                    local closestDistance = math.huge
                    
                    -- Busca a moeda mais próxima do mapa
                    for _, part in ipairs(coins) do
                        local distance = (root.Position - part.Position).Magnitude
                        if distance < closestDistance then
                            closestDistance = distance
                            targetCoin = part
                        end
                    end
                    
                    if targetCoin then
                        pcall(function()
                            -- Ativa Noclip para atravessar paredes sem travar
                            for _, bodyPart in pairs(char:GetDescendants()) do
                                if bodyPart:IsA("BasePart") then bodyPart.CanCollide = false end
                            end
                            
                            -- Anula a gravidade do boneco para estabilizar o movimento
                            root.Velocity = Vector3.new(0, 0, 0)
                            
                            -- Regra dos 300 metros (Studs): Teleporta direto se estiver muito longe
                            if closestDistance > 300 then
                                root.CFrame = targetCoin.CFrame
                                task.wait(0.05)
                            else
                                -- MODO NORMAL: Se a Posição Y estiver ativa, TELEPORTA direto para o alto
                                local offsetAltura = _G.AutoFarmPosicaoYAtivado and 12 or 1.3
                                local targetCFrame = targetCoin.CFrame * CFrame.new(0, offsetAltura, 0)
                                
                                if _G.AutoFarmPosicaoYAtivado then
                                    -- Em vez de ir voando para cima, define a posição direto no céu
                                    root.CFrame = CFrame.new(root.Position.X, targetCFrame.Y, root.Position.Z)
                                end
                                
                                -- Executa o voo suave de Tween de forma horizontal/direta até o alvo
                                local duration = (root.Position - targetCFrame.Position).Magnitude / _G.AutoFarmSpeed
                                local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
                                tween:Play()
                                tween.Completed:Wait() -- Espera o voo terminar
                                
                                -- Ao chegar na reta da moeda, TELEPORTA (desce) seco para coletar
                                if _G.AutoFarmPosicaoYAtivado and (root.Position - targetCFrame.Position).Magnitude < 3 then
                                    root.CFrame = targetCoin.CFrame
                                    task.wait(0.06) -- Delay mínimo para computar a moeda no servidor do MM2
                                end
                            end
                        end)
                    end
                end
            end
        end
    end
end)

