-- =============================================================================
local function GerenciarHighlight(objeto, nomeTag, corPreenchimento, corBorda, ativo)
    if ativo then
        local hl = objeto:FindFirstChild(nomeTag)
        if not hl then
            hl = Instance.new("Highlight")
            hl.Name = nomeTag
            hl.Adornee = objeto
            hl.Parent = objeto
        end
        hl.FillColor = corPreenchimento
        hl.FillTransparency = 0.6
        hl.OutlineColor = corBorda
        hl.OutlineTransparency = 0
    else
        local antigo = objeto:FindFirstChild(nomeTag)
        if antigo then antigo:Destroy() end
    end
end

