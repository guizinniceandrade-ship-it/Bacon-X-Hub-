RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if root and hum then
        -- Detecção nativa do estado de agachado no Flee the Facility
        local estaDeitado = (char:GetAttribute("Crouching") == true)
        
        -- Pega dinamicamente os valores de velocidade definidos pelos Sliders do menu
        local velocidadeAlvo = estaDeitado and _G.SpeedDeitadoValor or _G.SpeedValor
        local ativo = estaDeitado and _G.SpeedDeitadoAtivo or _G.SpeedAtivo

        -- Aplica o impulso de velocidade se o toggle correspondente estiver ativo e o player estiver andando
        if ativo and hum.MoveDirection.Magnitude > 0 then
            -- Bypass crucial: zera a WalkSpeed local para travar o controlador nativo do jogo
            hum.WalkSpeed = 0 
            
            BV.Parent = root
            BV.Velocity = hum.MoveDirection * velocidadeAlvo
        else
            -- Restaura a WalkSpeed base do jogo se você parar de andar ou desligar o toggle
            if hum.WalkSpeed == 0 then
                hum.WalkSpeed = estaDeitado and 8 or 16
            end
            BV.Parent = nil
        end
        
        -- Noclip Avançado Integrado (Combina troca de estado com remoção de colisão física)
        if _G.NoclipAtivo then
            hum:ChangeState(Enum.HumanoidStateType.NoClip)
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end
end)

