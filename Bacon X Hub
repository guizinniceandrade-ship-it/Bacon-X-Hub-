local function CriarSliderPlayer(textoNome, valorMin, valorMax, valorPadrao, funcaoCallback)
    local SliderFrame = Instance.new("Frame", PagePlayer)
    SliderFrame.Size = UDim2.new(1, -10, 0, 50)
    SliderFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 24)
