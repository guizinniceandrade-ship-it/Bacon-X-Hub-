-- Função Principal do Tween com Recuo de Posição (CFrame com Offset)
local function IniciarTweenVoando(cframeAlvo)
    local car = LocalPlayer.Character
    local hrp = car and car:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Aplica o recuo: 3 studs para cima e 4 studs para trás em relação à rotação do objeto
    -- Isso evita que você spawne "dentro" ou colando na parede do objeto
    local posicaoFinal = cframeAlvo * CFrame.new(0, 3, 4)

    local distancia = (hrp.Position - posicaoFinal.Position).Magnitude
    local velocidade = 40 -- Velocidade do voo
    local tempoDeVoo = distancia / velocidade

    hrp.Anchored = true

    local infoTween = TweenInfo.new(tempoDeVoo, Enum.EasingStyle.Linear)
    local voo = TweenService:Create(hrp, infoTween, {CFrame = posicaoFinal})
    
    CriarNotificacao("Teleporte", "Voando com recuo de segurança...", 2)
    voo:Play()
    
    voo.Completed:Connect(function()
        hrp.Anchored = false
        CriarNotificacao("Teleporte", "Chegou no ponto cego!", 1.5)
    end)
end

-- 1. LÓGICA DO TELEPORTE: PC (APENAS NÃO CONCLUÍDOS)
CriarLinhaTeleporte("Teleporte Pc", function()
    local computadores = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if (obj.Name == "ComputerTable" or obj.Name:match("Computer")) and obj:IsA("Model") then
            -- Verifica se o computador já foi hackeado/concluído
            -- O FTF costuma usar uma Screen ou uma PointLight verde/azul quando pronto.
            local esgotado = false
            local screen = obj:FindFirstChild("Screen", true)
            
            -- Se a tela do PC mudou de cor para verde (0, 255, ...) ou sumiu o objetivo, consideramos feito
            if screen and screen:IsA("Part") and screen.Color.G > 0.7 then
                esgotado = true
            end
            
            -- Também checa se existe alguma estampa ou texturas de concluído
            if obj:FindFirstChild("GreenLight", true) or obj:FindFirstChild("Completed", true) then
                esgotado = true
            end

            if not esgotado then
                table.insert(computadores, obj)
            end
        end
    end

    if #computadores > 0 then
        local pcEscolhido = computadores[math.random(1, #computadores)]
        -- Usa o CFrame do objeto principal para calcular a rotação e o recuo certo
        local primPart = pcEscolhido.PrimaryPart or pcEscolhido:FindFirstChild("Screen") or pcEscolhido:FindFirstChildOfClass("Part")
        if primPart then
            IniciarTweenVoando(primPart.CFrame)
        end
    else
        CriarNotificacao("Aviso", "Todos os PCs deste mapa já foram feitos!", 3)
    end
end)

