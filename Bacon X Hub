local function IniciarThreadHackRapido()
    task.spawn(function()
        while _G.HackRapidoAtivo do
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj.Name == "ComputerTable" and obj:IsA("Model") then
                    local Progresso = obj:FindFirstChild("Progress") or obj:FindFirstChild("Charge", true)
                    
                    if Progresso and Progresso:IsA("NumberValue") and Progresso.Value > 0 and Progresso.Value < 100 then
                        Progresso.Value = Progresso.Value + 1.5
                        task.wait(0.1)
                    end
