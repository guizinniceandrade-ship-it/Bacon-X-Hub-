-- ==========================================
-- GERENCIADOR DE ABAS ✅ AJUSTADO CONFORME SEU PEDIDO
-- ==========================================
local function AlternarAba(abaNome)
    -- ⚠️ AQUI: SÓ ATIVA A LINHA BRANCA NA ABA SELECIONADA, NADA MUDA ALÉM DISSO
    for nome, componentes in pairs(AbasCriadas) do
        if nome == abaNome then
            componentes.Stroke.Enabled = true -- Mostra linha branca
        else
            componentes.Stroke.Enabled = false -- Esconde linha das outras
        end
    end

    -- LIMPA AO TROCAR
    for _, child in pairs(ContainerPaginas:GetChildren()) do
        if child:IsA("GuiObject") and child ~= LayoutBotoes then
            child:Destroy()
        end
    end

    -- CARREGA
    if abaNome == "Main" then CarregarConteudo_Main()
    elseif abaNome == "ESP" then CarregarConteudo_ESP()
    elseif abaNome == "Local Player" then CarregarConteudo_LocalPlayer()
    elseif abaNome == "Teleporte" then CarregarConteudo_Teleporte() end
end

