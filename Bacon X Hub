-- 1. Sempre Acertar PC
local function IniciarThreadAutoHit()
    task.spawn(function()
        while _G.SempreAcertarPC do
            local PlayerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
            local HackGui = PlayerGui and PlayerGui:FindFirstChild("ScreenGui") and PlayerGui.ScreenGui:FindFirstChild("HackGui") or PlayerGui:FindFirstChild("HackGui", true)
            
            if HackGui and HackGui.Enabled then
                local PlayerMinigame = HackGui:FindFirstChild("ComputerProgress") or HackGui:FindFirstChild("MinigameFrame", true)
                if PlayerMinigame then
                    local Agulha = PlayerMinigame:FindFirstChild("Arrow") or PlayerMinigame:FindFirstChild("Pointer", true)
                    local ZonaSucesso = PlayerMinigame:FindFirstChild("SuccessZone") or PlayerMinigame:FindFirstChild("GreenZone", true)
                    
                    if Agulha and ZonaSucesso then
                        local distanciaZ = math.abs(Agulha.Rotation - ZonaSucesso.Rotation)
                        if distanciaZ < 8 then
                            game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, true, game, 1)
                            task.wait(0.05)
                            game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, false, game, 1)
                            task.wait(0.5)
                        end
                    end
                end
            end
            task.wait(0.01)
        end
    end)
end

CriarToggleAnimado("Sempre Acertar PC", function(state)
    _G.SempreAcertarPC = state
    if state then
        IniciarThreadAutoHit()
        CriarNotificacao("Hacking", "Skill Check no modo Auto-Hit Perfeito!", 2)
    else
        CriarNotificacao("Hacking", "Auto-Hit desligado.", 1.5)
    end
end)

