local isOpen = true 
local debounced = false

local function toggleMenu()
    if debounced then return end
    debounced = true
    
    local targetPos
    local targetVisible = true
    
    if not isOpen then
        MainFrame.Visible = true
        targetPos = UDim2.new(0.5, -275, 0.5, -175)
        isOpen = true
    else
        targetPos = UDim2.new(0.5, -275, -1.5, 0)
        isOpen = false
        targetVisible = false
    end
    
    local tween = TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = targetPos})
    tween:Play()
    
    tween.Completed:Connect(function()
        MainFrame.Visible = targetVisible
        debounced = false
    end)
end

ToggleButton.MouseButton1Click:Connect(toggleMenu)


