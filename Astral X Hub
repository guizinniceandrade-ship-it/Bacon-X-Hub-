	star.BorderSizePixel = 0
	star.BackgroundTransparency = math.random(0, 7) / 10
	star.ZIndex = 1
	star.Parent = StarsContainer

	table.insert(stars, {
		obj = star,
		speedX = (math.random(2, 6)) / 1000,
		speedY = (math.random(2, 6)) / 1000,
	})
end

task.spawn(function()
	while MainFrame.Parent do
		for _, s in ipairs(stars) do
			local pos = s.obj.Position
			local newX = pos.X.Scale + s.speedX
			local newY = pos.Y.Scale + s.speedY
			if newX > 1 then newX = 0 end
			if newY > 1 then newY = 0 end
			s.obj.Position = UDim2.new(newX, 0, newY, 0)
		end
		task.wait(0.03)
	end
end)

