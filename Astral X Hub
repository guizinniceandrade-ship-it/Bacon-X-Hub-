local NOMES_SAIDA = {["exitdoor"] = true}

local function ehPC(n) return NOMES_PC[n] ~= nil end
local function ehCapsula(n) return NOMES_CAPSULA[n] ~= nil end
local function ehSaida(n) return NOMES_SAIDA[n] ~= nil end

local function pcCompletado(obj)
    for _, child in pairs(obj:GetDescendants()) do
        if child:IsA("BasePart") and child.Name == "Screen" then
            if child.BrickColor == BrickColor.new("Bright green") or
               child.BrickColor == BrickColor.new("Lime green") or
               child.BrickColor == BrickColor.new("Bright red") or
               child.Color.G > 0.4 and child.Color.R < 0.4 and child.Color.B < 0.4 then
                return true
            end
        end
    end
    return false
end

local function CriarOuAtualizarHighlight(alvo, corP, corB)
    if not alvo then return end
    local hl = alvo:FindFirstChild("ESP_MARCADOR")
    if not hl then
        hl = Instance.new("Highlight")
        hl.Name = "ESP_MARCADOR"
        hl.Adornee = alvo
        hl.FillTransparency = 0.4
        hl.OutlineTransparency = 0.2
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = alvo
    end
    hl.FillColor = corP
    hl.OutlineColor = corB
end

local function CriarHighlight(alvo, corP, corB)
    if not alvo or alvo:FindFirstChild("ESP_MARCADOR") then return end
    local hl = Instance.new("Highlight")
    hl.Name = "ESP_MARCADOR"; hl.Adornee = alvo; hl.FillColor = corP; hl.OutlineColor = corB
    hl.FillTransparency = 0.4; hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = alvo
end

local function LimparPorFiltro(filtro)
    for _, o in pairs(Workspace:GetDescendants()) do
        if o:IsA("Model") and o:FindFirstChild("ESP_MARCADOR") then
            if filtro(o.Name:lower()) then
                o.ESP_MARCADOR:Destroy()
            end
        end
    end
end

