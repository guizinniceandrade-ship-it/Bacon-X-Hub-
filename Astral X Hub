local ToggleSound = Instance.new("Sound")
ToggleSound.SoundId = "rbxassetid://140207837688369"
ToggleSound.Volume = 0.5
ToggleSound.Parent = ScreenGui

local isOpen = false
local animTweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out) -- Suave e com impulso

-- 🚀 ANIMAÇÃO DE ENTRADA AUTOMÁTICA (sobe de baixo para o centro)
task.delay(0.1, function()
    TweenService:Create(MainFrame, animTweenInfo, {Position = UDim2.new(0.5, -275, 0.5, -175)}):Play()
    isOpen = true
end)

ToggleButton.MouseButton1Click:Connect(function()
	ToggleSound:Play()
	isOpen = not isOpen
	
	if isOpen then
		-- ✅ ABRIR: Sobe de BAIXO para o CENTRO
		MainFrame.Visible = true
		MainFrame.Position = UDim2.new(0.5, -275, 1.5, -175) -- Começa embaixo
		TweenService:Create(MainFrame, animTweenInfo, {Position = UDim2.new(0.5, -275, 0.5, -175)}):Play()
	else
		-- ❌ FECHAR: Desce para BAIXO e desaparece
		local tweenFechar = TweenService:Create(MainFrame, animTweenInfo, {Position = UDim2.new(0.5, -275, 1.5, -175)})
		tweenFechar:Play()
		tweenFechar.Completed:Connect(function()
			MainFrame.Visible = false
		end)
	end
end)
