end

-- Tween PC (só PCs não completados)
CriarBotaoTeleporte("Tween PC", pageTeleporte, function()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local maisProximo, menorDist = nil, math.huge
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and NOMES_PC[obj.Name:lower()] then
            -- Só teleporta para PCs não completados
            local completado = false
            for _, child in pairs(obj:GetDescendants()) do
                if child:IsA("BasePart") and child.Name == "Screen" then
                    if child.BrickColor == BrickColor.new("Bright green") or
                       child.BrickColor == BrickColor.new("Lime green") or
                       child.BrickColor == BrickColor.new("Bright red") or
                       (child.Color.G > 0.4 and child.Color.R < 0.4 and child.Color.B < 0.4) then
                        completado = true
                    end
                end
            end
            if not completado then
                local parte = obj:FindFirstChildWhichIsA("BasePart")
                if parte then
                    local dist = (root.Position - parte.Position).Magnitude
                    if dist < menorDist then
                        menorDist = dist
                        maisProximo = parte
                    end
                end
            end
        end
    end
    TweenParaAlvo(maisProximo)
end)

