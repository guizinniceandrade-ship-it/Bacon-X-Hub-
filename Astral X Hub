-- 🪂 INFINITE JUMP (Toggle Animado - Fundo Branco ao ativar)
local InfiniteJumpAtivado = false
local ConexaoJump

CriarToggleAnimado("Infinite Jump", pages["Local Player"], function(ativado)
    InfiniteJumpAtivado = ativado

    if ativado then
        ConexaoJump = UserInputService.JumpRequest:Connect(function()
            if humanoid and humanoid.FloorMaterial == Enum.Material.Air then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    else
        if ConexaoJump then ConexaoJump:Disconnect() end
    end
end)

-- 👻 NOCLIP (Toggle Animado - Fundo Branco ao ativar)
local NoclipAtivado = false
local ConexaoNoclip

CriarToggleAnimado("Noclip", pages["Local Player"], function(ativado)
    NoclipAtivado = ativado

    if ativado then
        ConexaoNoclip = RunService.Stepped:Connect(function()
            if humanoid and rootPart then
                humanoid.CanCollide = false
                for _, parte in pairs(character:GetChildren()) do
                    if parte:IsA("BasePart") then
                        parte.CanCollide = false
                    end
                end
            end
        end)
    else
        if ConexaoNoclip then ConexaoNoclip:Disconnect() end
        if humanoid then humanoid.CanCollide = true end
        for _, parte in pairs(character:GetChildren()) do
            if parte:IsA("BasePart") then
                parte.CanCollide = true
            end
        end
    end
end)

