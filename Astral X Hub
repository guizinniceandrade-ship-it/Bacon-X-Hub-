end
local CanalSom = ReplicatedStorage:WaitForChild("CanalDeSomGlobal")

-- Lista de sons com voz/funk
local ListaDeSons = {
    {Nome = "Vai Malandro", Id = "105473229406795"},
    {Nome = "Ativado", Id = "116394328501973"},
    {Nome = "Desligado", Id = "116394368291057"},
    {Nome = "Batidão", Id = "116394389201836"},
    {Nome = "Uh Grito", Id = "98322675121824"},
    {Nome = "Olha o Som", Id = "6490661033"}
}

-- Servidor tocar som para todos
if RunService:IsServer() then
    CanalSom.OnServerEvent:Connect(function(player, idSom)
        local Som = Instance.new("Sound")
        Som.SoundId = "rbxassetid://"..idSom
        Som.Volume = 0.9
        Som.Parent = SoundService
        Som:Play()
        Som.Ended:Connect(function() Som:Destroy() end)
    end)
end

local function TocarSomGlobal(nomeSom)
    for _, som in pairs(ListaDeSons) do
        if som.Nome == nomeSom then
            CanalSom:FireServer(som.Id)
            break
        end
    end
end

-- Função para criar TOGGLE (LIGA/DESLIGA)
local function CriarToggle(texto, pai, funcao)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Size = UDim2.new(1, -8, 0, 32)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    ToggleFrame.Parent = pai

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = ToggleFrame

    local Texto = Instance.new("TextLabel")
    Texto.Size = UDim2.new(1, -50, 1, 0)
    Texto.Position = UDim2.new(0, 10, 0, 0)
    Texto.BackgroundTransparency = 1
    Texto.Text = texto
    Texto.TextColor3 = Color3.new(1,1,1) -- BRANCO
    Texto.Font = Enum.Font.Gotham
    Texto.TextSize = 13
    Texto.TextXAlignment = Enum.TextXAlignment.Left
    Texto.Parent = ToggleFrame

    local Botao = Instance.new("TextButton")
    Botao.Size = UDim2.new(0, 30, 0, 16)
    Botao.Position = UDim2.new(1, -40, 0.5, -8)
    Botao.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Botao.Text = ""
    Botao.AutoButtonColor = false
    Botao.Parent = ToggleFrame

    local BotaoCorner = Instance.new("UICorner")
    BotaoCorner.CornerRadius = UDim.new(1, 0)
    BotaoCorner.Parent = Botao

    local Bolinha = Instance.new("Frame")
    Bolinha.Size = UDim2.new(0, 12, 0, 12)
    Bolinha.Position = UDim2.new(0, 2, 0.5, -6)
    Bolinha.BackgroundColor3 = Color3.new(1,1,1) -- BRANCO
    Bolinha.Parent = Botao

    local BolinhaCorner = Instance.new("UICorner")
    BolinhaCorner.CornerRadius = UDim.new(1, 0)
    BolinhaCorner.Parent = Bolinha

    local Ativado = false
    Botao.MouseButton1Click:Connect(function()
        Ativado = not Ativado
        TocarSomGlobal(Ativado and "Ativado" or "Desligado")
        if Ativado then
            TweenService:Create(Bolinha, TweenInfo.new(0.2), {
                Position = UDim2.new(0, 16, 0.5, -6),
                BackgroundColor3 = Color3.new(1,1,1) -- BRANCO
            }):Play()
        else
            TweenService:Create(Bolinha, TweenInfo.new(0.2), {
                Position = UDim2.new(0, 2, 0.5, -6),
                BackgroundColor3 = Color3.new(1,1,1) -- BRANCO
            }):Play()
        end
        funcao(Ativado)
    end)
end

-- Função para criar BOTÃO NORMAL
local function CriarBotao(texto, pai, funcao)
    local Botao = Instance.new("TextButton")
    Botao.Size = UDim2.new(1, -8, 0, 32)
    Botao.BackgroundColor3 = Color3.fromRGB(20,20,20)
    Botao.Text = texto
    Botao.TextColor3 = Color3.new(1,1,1) -- BRANCO
    Botao.Font = Enum.Font.Gotham
    Botao.TextSize = 13
    Botao.AutoButtonColor = false
    Botao.Parent = pai

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = Botao

    Botao.MouseEnter:Connect(function()
        TweenService:Create(Botao, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35,35,35)}):Play()
    end)
    Botao.MouseLeave:Connect(function()
        TweenService:Create(Botao, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(20,20,20)}):Play()
    end)

    Botao.MouseButton1Click:Connect(function()
        TocarSomGlobal("Batidão")
        funcao()
    end)
end

