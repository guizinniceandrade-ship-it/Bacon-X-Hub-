-- Motor do ESP
local lastUpdate = 0
RunService.RenderStepped:Connect(function()
    if tick() - lastUpdate < 0.6 then return end
    lastUpdate = tick()

    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChildWhichIsA("BasePart") then
            local n = obj.Name:lower()

            if estadosESP["ESP PC"] and ehPC(n) then
                local completado = pcCompletado(obj)
                CriarOuAtualizarHighlight(
                    obj,
                    completado and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(80, 180, 255),
                    Color3.new(0, 0, 0)
                )
            elseif estadosESP["ESP Cápsulas"] and ehCapsula(n) then
                CriarHighlight(obj, Color3.fromRGB(255, 200, 0), Color3.fromRGB(180, 120, 0))
            elseif estadosESP["ESP Saida"] and ehSaida(n) then
                CriarHighlight(obj, Color3.fromRGB(255, 80, 0), Color3.fromRGB(150, 40, 0))
            end
        end
    end

    if estadosESP["ESP Jogadores"] then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local ehFera = false
                if p.Team then
                    local teamName = p.Team.Name:lower()
                    ehFera = teamName:find("beast") ~= nil or teamName:find("fera") ~= nil or teamName:find("hunter") ~= nil
                end
                if not ehFera then
                    ehFera = p.Character:FindFirstChild("Hammer") ~= nil
                        or p.Character:FindFirstChild("Mallet") ~= nil
                        or p.Character:FindFirstChild("Claw") ~= nil
                end
                if not ehFera then
                    local hum = p.Character:FindFirstChildOfClass("Humanoid")
                    if hum and hum.DisplayName ~= p.DisplayName then ehFera = true end
                end
                CriarOuAtualizarHighlight(p.Character,
                    ehFera and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0),
                    Color3.new(0, 0, 0)
                )
            end
        end
    else
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("ESP_MARCADOR") then
                p.Character.ESP_MARCADOR:Destroy()
            end
        end
    end
end)

