local function selectTab(name)
	for tabName, dados in pairs(tabButtons) do
		local isSelected = (tabName == name)
		dados.Botao.BackgroundColor3 = isSelected and Color3.fromRGB(35, 35, 35) or Color3.fromRGB(20, 20, 20)
		if dados.Stroke then dados.Stroke.Transparency = isSelected and 0 or 1 end
	end
	for pageName, page in pairs(pages) do
		page.Visible = (pageName == name)
	end
end

