-- ✅ SLIDER CORRIGIDO DE VEZ - AGORA ARRASTA SEM TRAVAR NUNCA!
-- Mudei toda a lógica de detecção de clique, é a forma mais garantida que existe
local function CriarSlider(texto, pai, min, max, padrao, funcao)
    local SliderFrame = Instance.new("Frame")
    SliderFrame.Size = UDim2.new(1, -8, 0, 55)
    SliderFrame.BackgroundColor3 = Color3.fromRGB(15,15,15)
    SliderFrame.BorderSizePixel = 0
    SliderFrame.Parent = pai
    Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0,8)

    local Texto = Instance.new("TextLabel", SliderFrame)
    Texto.Size = UDim2.new(1, -50, 0, 20)
    Texto.Position = UDim2.new(0, 10, 0, 5)
    Texto.BackgroundTransparency = 1
    Texto.Text = texto
    Texto.TextColor3 = Color3.new(1,1,1)
    Texto.Font = Enum.Font.Gotham
    Texto.TextSize = 13
    Texto.TextXAlignment = Enum.TextXAlignment.Left

    local Valor = Instance.new("TextLabel", SliderFrame)
    Valor.Size = UDim2.new(0, 40, 0, 20)
    Valor.Position = UDim2.new(1, -45, 0, 5)
    Valor.BackgroundTransparency = 1
    Valor.Text = tostring(padrao)
    Valor.TextColor3 = Color3.new(1,1,1)
    Valor.Font = Enum.Font.GothamBold
    Valor.TextSize = 13
    Valor.TextXAlignment = Enum.TextXAlignment.Right

    -- Área onde o slider mexe
    local BarraFundo = Instance.new("Frame", SliderFrame)
    BarraFundo.Size = UDim2.new(1, -20, 0, 8)
    BarraFundo.Position = UDim2.new(0, 10, 1, -18)
    BarraFundo.BackgroundColor3 = Color3.fromRGB(40,40,40)
    BarraFundo.BorderSizePixel = 0
    BarraFundo.ZIndex = 2
    Instance.new("UICorner", BarraFundo).CornerRadius = UDim.new(1,0)

    local BarraCheia = Instance.new("Frame", BarraFundo)
    BarraCheia.Size = UDim2.new((padrao-min)/(max-min), 0, 1, 0)
    BarraCheia.BackgroundColor3 = Color3.new(1,1,1)
    BarraCheia.BorderSizePixel = 0
    BarraCheia.ZIndex = 3
    Instance.new("UICorner", BarraCheia).CornerRadius = UDim.new(1,0)

    -- BOTÃOZINHO: AGORA USA O MÉTODO GLOBAL DE CLIQUE, NÃO TRAVA MAIS
    local Botao = Instance.new("Frame", BarraFundo)
    Botao.Size = UDim2.new(0, 16, 0, 16)
    Botao.Position = UDim2.new((padrao-min)/(max-min), -8, 0.5, -8)
    Botao.BackgroundColor3 = Color3.new(1,1,1)
    Botao.BorderSizePixel = 0
    Botao.ZIndex = 4
    Instance.new("UICorner", Botao).CornerRadius = UDim.new(1,0)

    -- 🚫 NÃO USO MAIS O InputBegan DO BOTÃO, AGRA PEGO O CLIQUE GERAL DA TELA
    local arrastando = false

    -- Função que atualiza tudo (testada e aprovada)
    local function Atualizar()
        if not arrastando then return end

        -- Pega a posição do mouse EM RELAÇÃO A BARRA
        local mousePos = UserInputService:GetMouseLocation().X
        local barraInicio = BarraFundo.AbsolutePosition.X
        local barraTamanho = BarraFundo.AbsoluteSize.X
        local posRelativa = mousePos - barraInicio

        -- Calcula a porcentagem e o valor
        local proporcao = math.clamp(posRelativa / barraTamanho, 0, 1)
        local valorAtual = math.floor(min + (max - min) * proporcao + 0.5)

        -- Atualiza visual
        BarraCheia.Size = UDim2.new(proporcao, 0, 1, 0)
        Botao.Position = UDim2.new(proporcao, -8, 0.5, -8)
        Valor.Text = tostring(valorAtual)

        -- Manda valor pra função
        funcao(valorAtual)
    end

    -- ✅ AGORA SIM: Detecta o clique EM QUALQUER LUGAR, se for no botão, começa a arrastar
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Verifica se o mouse está em cima do botãozinho
            local mouseX, mouseY = UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y
            local btnPos = Botao.AbsolutePosition
            local btnTam = Botao.AbsoluteSize

            if mouseX >= btnPos.X and mouseX <= btnPos.X + btnTam.X and mouseY >= btnPos.Y and mouseY <= btnPos.Y + btnTam.Y then
                arrastando = true
                Atualizar() -- Já atualiza no primeiro clique
            end
        end
    end)

    -- ✅ Quando solta o clique, para de arrastar
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            arrastando = false
        end
    end)

    -- ✅ Enquanto mexe o mouse e está segurando, atualiza
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            Atualizar()
        end
    end)

    return SliderFrame
end

