local VELOCIDADE_TWEEN = 50

local function TweenParaAlvo(alvo)
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root or not alvo then return end

    local distancia = (root.Position - alvo.Position).Magnitude
    local tempo = distancia / VELOCIDADE_TWEEN

    local tweenInfo = TweenInfo.new(tempo, Enum.EasingStyle.Linear)
    TweenService:Create(root, tweenInfo, {CFrame = alvo.CFrame + Vector3.new(0, 3, 0)}):Play()
end

