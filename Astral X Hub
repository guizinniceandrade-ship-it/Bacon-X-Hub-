-- Função para formatar tempo (segundos -> 0:00)
local function FormatarTempo(segundos)
    local min = math.floor(segundos / 60)
    local seg = math.floor(segundos % 60)
    return string.format("%d:%02d", min, seg)
end

-- Atualiza barra e tempo em tempo real
local function AtualizarPlayer()
    if not MusicaAtual or not MusicaAtual.IsPlaying then
        PlayPauseBtn.Text = "▶"
        return
    end
    PlayPauseBtn.Text = "⏸"
    TempoAtual.Text = FormatarTempo(MusicaAtual.TimePosition)
    TempoTotal.Text = FormatarTempo(MusicaAtual.TimeLength)
    BarraProgresso.Size = UDim2.new(MusicaAtual.TimePosition / MusicaAtual.TimeLength, 0, 1, 0)
end

-- Parar tudo
local function PararMusica()
    if MusicaAtual then
        MusicaAtual:Stop()
        MusicaAtual:Destroy()
        MusicaAtual = nil
    end
    if AtualizacaoBarra then AtualizacaoBarra:Disconnect() end
    NomeMusicaLabel.Text = "Nenhuma música tocando"
    TempoAtual.Text = "0:00"
    TempoTotal.Text = "0:00"
    BarraProgresso.Size = UDim2.new(0,0,1,0)
    PlayPauseBtn.Text = "▶"
end

-- Tocar música por índice
local function TocarMusicaIndice(indice)
    if not ListaDeMusicas[indice] then return end
    PararMusica()
    IndiceAtual = indice

    local dados = ListaDeMusicas[indice]
    MusicaAtual = Instance.new("Sound")
    MusicaAtual.Name = "MusicaDoHub"
    MusicaAtual.SoundId = "rbxassetid://"..dados.id
    MusicaAtual.Volume = 0.5
    MusicaAtual.Looped = false
    MusicaAtual.Parent = SoundService
    MusicaAtual:Play()

    NomeMusicaLabel.Text = dados.nome
    CriarNotificacao("🎵 Tocando agora", dados.nome, 3)

    -- Atualiza a barra a cada 0.2s
    AtualizacaoBarra = game:GetService("RunService").RenderStepped:Connect(AtualizarPlayer)

    -- Quando acabar, toca a próxima
    MusicaAtual.Ended:Connect(function()
        if IndiceAtual < #ListaDeMusicas then
            TocarMusicaIndice(IndiceAtual + 1)
        end
    end)
end

-- Ações dos botões do player
PlayPauseBtn.MouseButton1Click:Connect(function()
    TocarSom()
    if not MusicaAtual then return end
    if MusicaAtual.IsPlaying then
        MusicaAtual:Pause()
        PlayPauseBtn.Text = "▶"
    else
        MusicaAtual:Resume()
        PlayPauseBtn.Text = "⏸"
    end
end)

VoltarBtn.MouseButton1Click:Connect(function()
    TocarSom()
    local novo = IndiceAtual - 1
    if novo < 1 then novo = #ListaDeMusicas end
    TocarMusicaIndice(novo)
end)

AvancarBtn.MouseButton1Click:Connect(function()
    TocarSom()
    local novo = IndiceAtual + 1
    if novo > #ListaDeMusicas then novo = 1 end
    TocarMusicaIndice(novo)
end)

