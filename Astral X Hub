-- =========================
local function selectTab(name)
	for tabName, btn in pairs(tabButtons) do
		local isSelected = (tabName == name)
		btn.BackgroundColor3 = isSelected and Color3.fromRGB(35, 35, 35) or Color3.fromRGB(20, 20, 20)
		
		-- ✨ LINHA APARECE E CONTORNA TODA A CAIXA ✨
		local stroke = btn:FindFirstChildOfClass("UIStroke")
		if stroke then
			stroke.Transparency = isSelected and 0 or 1
			stroke.Thickness = isSelected and 2 or 1.8
		end
	end
	for pageName, page in pairs(pages) do
		page.Visible = (pageName == name)
	end
end

